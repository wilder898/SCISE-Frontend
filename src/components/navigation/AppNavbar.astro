---
const currentPath = Astro.url.pathname;
const links = [
  { href: "/reportes", label: "Panel de Administración", icon: "bar" },
  { href: "/ingreso", label: "Registrar Ingreso", icon: "enter" },
  { href: "/salida", label: "Registrar Salida", icon: "exit" },
  { href: "/usuarios", label: "Gestionar Usuarios", icon: "users" },
  { href: "/configuracion", label: "Configuración", icon: "settings", adminOnly: true },
];
---

<aside class="app-sidebar">
  <div class="app-sidebar-top">
    <a class="app-sidebar-brand" href="/dashboard" aria-label="Ir al dashboard">
      <span class="brand-badge">S</span>
      <span class="brand-text">
        <strong>SCISE</strong>
        <small>Sistema de Control</small>
      </span>
    </a>

    <div class="app-sidebar-user">
      <span class="user-name" data-sidebar-name>Admin SENA</span>
      <span class="user-role" data-sidebar-role>Administrador</span>
    </div>
  </div>

  <div class="app-sidebar-middle">
    <nav class="app-nav" aria-label="Navegacion principal">
      {
        links.map((link) => {
          const isActive = currentPath === link.href || currentPath.startsWith(`${link.href}/`);

          return (
            <a
              href={link.href}
              class:list={["app-nav-link", isActive ? "is-active" : "is-ghost"]}
              aria-current={isActive ? "page" : undefined}
              hidden={link.adminOnly}
              data-admin-only={link.adminOnly ? "true" : undefined}
            >
              <span class:list={["nav-icon", `is-${link.icon}`]} aria-hidden="true">
                {link.icon === "bar" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M5 20V4M12 20V10M19 20V7"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                    />
                  </svg>
                )}
                {link.icon === "enter" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M10 5l7 7-7 7M4 12h13"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
                {link.icon === "exit" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M14 5l-7 7 7 7M20 12H7"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
                {link.icon === "users" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M16 11a4 4 0 1 0-8 0M4 20a6 6 0 0 1 16 0"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                    />
                  </svg>
                )}
                {link.icon === "settings" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    />
                    <path
                      d="M19.4 15a1 1 0 0 0 .2 1.1l.1.1a2 2 0 0 1-2.8 2.8l-.1-.1a1 1 0 0 0-1.1-.2 1 1 0 0 0-.6.9V20a2 2 0 0 1-4 0v-.1a1 1 0 0 0-.6-.9 1 1 0 0 0-1.1.2l-.1.1a2 2 0 0 1-2.8-2.8l.1-.1a1 1 0 0 0 .2-1.1 1 1 0 0 0-.9-.6H4a2 2 0 0 1 0-4h.1a1 1 0 0 0 .9-.6 1 1 0 0 0-.2-1.1l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1 1 0 0 0 1.1.2 1 1 0 0 0 .6-.9V4a2 2 0 0 1 4 0v.1a1 1 0 0 0 .6.9 1 1 0 0 0 1.1-.2l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1 1 0 0 0-.2 1.1 1 1 0 0 0 .9.6H20a2 2 0 0 1 0 4h-.1a1 1 0 0 0-.9.6Z"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
              </span>
              <span>{link.label}</span>
            </a>
          );
        })
      }
    </nav>
  </div>

  <div class="app-sidebar-bottom">
    <a class="app-logout" href="/auth/login" id="logoutButton">Cerrar sesión</a>
  </div>
</aside>

<script>
  const API_BASE_URL = (import.meta.env.PUBLIC_API_BASE_URL || "http://localhost:8000/api/v1").replace(/\/$/, "");
  function readSession() {
    try {
      const raw = localStorage.getItem("scise-session");
      if (!raw) {
        return {};
      }

      const parsed = JSON.parse(raw);
      return parsed && typeof parsed === "object" ? parsed : {};
    } catch {
      return {};
    }
  }

  function resolveIsAdmin(session: Record<string, unknown>) {
    const roleValue = String(session?.role || session?.rol || "").toLowerCase();
    const backendRole = String(session?.roleBackend || "").toUpperCase();
    return roleValue === "admin" || roleValue === "administrador" || backendRole === "ADMINISTRADOR";
  }

  const sessionData = readSession();
  const isAdmin = resolveIsAdmin(sessionData);
  const sidebarName = document.querySelector("[data-sidebar-name]");
  const sidebarRole = document.querySelector("[data-sidebar-role]");
  const adminOnlyLinks = document.querySelectorAll('[data-admin-only="true"]');
  const logoutButton = document.getElementById("logoutButton");

  adminOnlyLinks.forEach((link) => {
    if (link instanceof HTMLElement) {
      link.hidden = !isAdmin;
    }
  });

  if (sidebarName instanceof HTMLElement) {
    sidebarName.textContent = isAdmin ? "Admin SENA" : "Usuario SCISE";
  }

  if (sidebarRole instanceof HTMLElement) {
    sidebarRole.textContent = isAdmin ? "Administrador" : "Usuario";
  }

  async function logout() {
    const token = localStorage.getItem("scise-auth-token");

    if (token) {
      try {
        await fetch(`${API_BASE_URL}/auth/logout`, {
          method: "POST",
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });
      } catch {
        // Logout local continues even if backend call fails.
      }
    }

    localStorage.removeItem("scise-auth-token");
    localStorage.removeItem("scise-session");
    window.location.href = "/auth/login";
  }

  logoutButton?.addEventListener("click", (event) => {
    event.preventDefault();
    logout();
  });
</script>

<style is:global>
  .app-sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
  }

  .app-sidebar-middle {
    min-height: 0;
    overflow-y: auto;
    padding-right: 0.15rem;
  }

  .app-sidebar-bottom {
    flex-shrink: 0;
    padding-top: 0.35rem;
    background: var(--color-primary);
  }

  @media (max-width: 900px) {
    .app-sidebar {
      position: static;
      height: auto;
      overflow: visible;
    }

    .app-sidebar-middle {
      overflow: visible;
      padding-right: 0;
    }
  }
</style>

