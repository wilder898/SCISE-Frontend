---
import AuthLayout from "../../layouts/AuthLayout.astro";
import LoginView from "../../features/auth/LoginView.astro";
import "../../styles/login.css";
---

<AuthLayout title="SCISE - Login">
  <div class="auth-card">
    <LoginView />
  </div>
</AuthLayout>

<script>
  const users = [
    { username: "admin", password: "admin123", role: "admin" },
    { username: "user", password: "user123", role: "user" },
  ];

  const form = document.getElementById("loginForm");
  const usernameInput = document.getElementById("username");
  const passwordInput = document.getElementById("password");
  const loading = document.getElementById("loading");
  const error = document.getElementById("error");

  if (form && usernameInput && passwordInput && loading && error) {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      error.textContent = "";
      loading.textContent = "Validando credenciales...";

      const username = String(usernameInput.value || "").trim();
      const password = String(passwordInput.value || "");

      const match = users.find(
        (user) => user.username === username && user.password === password
      );

      if (!match) {
        loading.textContent = "";
        error.textContent = "Usuario o contraseña incorrectos.";
        return;
      }

      // Guardar sesión mínima para uso posterior (si se requiere).
      localStorage.setItem(
        "scise-session",
        JSON.stringify({
          username: match.username,
          role: match.role,
          loginAt: new Date().toISOString(),
        })
      );

      window.location.href = "/ingreso";
    });
  }
</script>

