---
import AppLayout from "../../layouts/AppLayout.astro";
import DashbordAdmin from "../../features/dashboard/dashbordAdmin.astro";
import "../../styles/dashbordAdmin.css";
---

<AppLayout title="SCISE - Dashboard Administrador">
  <DashbordAdmin />
</AppLayout>

<script>
  // Guard de seguridad: solo accesible para admins
  const raw = localStorage.getItem("scise-session");
  if (!raw) {
    window.location.replace("/auth/login");
  } else {
    try {
      const session = JSON.parse(raw);
      if (session.role !== "admin") {
        window.location.replace("/dashboard/user");
      }
    } catch {
      window.location.replace("/auth/login");
    }
  }

  // Botón cerrar sesión
  const logoutBtn = document.getElementById("logoutBtn");
  if (logoutBtn) {
    logoutBtn.addEventListener("click", () => {
      localStorage.removeItem("scise-session");
      window.location.href = "/auth/login";
    });
  }
</script>
