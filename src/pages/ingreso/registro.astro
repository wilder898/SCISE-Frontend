---
import AppLayout from "../../layouts/AppLayout.astro";
import IngresoView from "../../features/ingreso/ingresoView.astro";
import "../../styles/equipos.css";
---

<AppLayout title="SCISE - Ingreso">
  <IngresoView />
</AppLayout>

<script>
  // Guard de seguridad: solo accesible para usuarios autenticados
  const raw = localStorage.getItem("scise-session");
  if (!raw) {
    window.location.replace("/auth/login");
  } else {
    try {
      const session = JSON.parse(raw);
      if (session.role !== "admin" && session.role !== "user") {
        window.location.replace("/auth/login");
      }
    } catch {
      window.location.replace("/auth/login");
    }
  }
</script>