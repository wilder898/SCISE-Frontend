---
import BaseLayout from "./BaseLayout.astro";
import AppNavbar from "../components/navigation/AppNavbar.astro";
import AppHeader from "../components/navigation/AppHeader.astro";

interface Props {
  title?: string;
}

const { title = "SCISE - App" } = Astro.props;
---

<BaseLayout title={title}>
  <div class="app-shell">
    <AppNavbar />
    <main class="app-content">
      <AppHeader title={title} />
      <slot />
    </main>
  </div>
</BaseLayout>
