<article class="ingreso-card">
  <header class="ingreso-card__header">
    <span class="ingreso-icon is-blue" aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M7 4h10v16H7zM9 8h6M9 12h6M9 16h4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
    </span>
    <h2>Escanear Carnet o Documento</h2>
    <button id="registerUserButton" class="register-user-button" type="button" aria-label="Registrar nuevo usuario">
      <svg viewBox="0 0 24 24" width="20" height="20">
        <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
    </button>
  </header>

  <section class="scan-area">
    <div class="scan-area__controls">
      <input
        type="text"
        id="barcodeUser"
        class="scan-input"
        placeholder="Escanear carnet o escribir documento..."
        autocomplete="off"
      />
      <button
        id="scanReaderButton"
        class="scan-reader-button"
        type="button"
        aria-label="Usar camara para escanear el carnet"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 8.5A2.5 2.5 0 0 1 6.5 6H9l1.2-1.6h3.6L15 6h2.5A2.5 2.5 0 0 1 20 8.5v7A2.5 2.5 0 0 1 17.5 18h-11A2.5 2.5 0 0 1 4 15.5z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path>
          <circle cx="12" cy="12" r="3.2" fill="none" stroke="currentColor" stroke-width="1.8"></circle>
        </svg>
        <span id="scanReaderButtonLabel">Usar Camara</span>
      </button>
    </div>
  </section>

  <p id="scanReaderStatus" class="scan-reader-status oculto"></p>
  <section id="cameraScannerBox" class="camera-scanner oculto" aria-live="polite">
    <div class="camera-scanner__toolbar">
      <label class="camera-scanner__field">
        <span class="camera-scanner__label">Camara</span>
        <select id="cameraDeviceSelect" class="camera-scanner__select">
          <option value="">Camara predeterminada</option>
        </select>
      </label>

      <button
        id="cameraRefreshButton"
        class="camera-scanner__secondary-button"
        type="button"
      >
        Actualizar
      </button>
      <button
        id="cameraMirrorToggleButton"
        class="camera-scanner__secondary-button is-active oculto"
        type="button"
      >
        <span id="cameraMirrorToggleLabel">Eje Corregido</span>
      </button>
    </div>

    <div class="camera-scanner__frame">
      <video
        id="cameraScannerVideo"
        class="camera-scanner__video is-flipped"
        playsinline
        muted
        autoplay
      ></video>
      <div class="camera-scanner__overlay" aria-hidden="true">
        <span class="camera-scanner__guide"></span>
      </div>
    </div>

    <div class="camera-scanner__actions">
      <p class="camera-scanner__hint">
        Ubica el codigo de barras del carnet dentro del recuadro para leer el documento.
      </p>
      <div class="camera-scanner__buttons">
        <button
          id="cameraCaptureButton"
          class="camera-scanner__capture-button"
          type="button"
        >
          Capturar y Escanear
        </button>
        <button
          id="cameraScannerCloseButton"
          class="camera-scanner__close-button"
          type="button"
        >
          Cerrar Camara
        </button>
      </div>
    </div>
  </section>
  <p id="userSuccess" class="success oculto">Usuario detectado correctamente.</p>
  <p id="userError" class="error oculto"></p>
  <p id="loadingUser" class="loading oculto">Cargando usuario...</p>

  <section id="userBox" class="user-box oculto">
    <p><strong>Nombre</strong><br /><span id="nombre"></span></p>
    <p><strong>Documento</strong><br /><span id="documento"></span></p>
    <p><strong>Rol</strong><br /><span id="rol"></span></p>
  </section>
</article>
