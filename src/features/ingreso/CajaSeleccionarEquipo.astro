<article class="ingreso-card">
  <header class="ingreso-card__header">
    <span class="ingreso-icon is-orange" aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <rect x="4" y="6" width="16" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="2"></rect>
        <path d="M8 20h8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
    </span>
    <h2>Seleccionar Equipo</h2>
  </header>

  <p id="textoInicial" class="descripcion">
    Escanea primero el carnet del usuario para ver los equipos disponibles para
    registrar ingreso.
  </p>

  <p id="loadingEquipos" class="loading oculto">Cargando equipos...</p>
  <p id="equiposError" class="error oculto"></p>

  <section id="listaEquipos" class="equipos oculto">
    <!-- Los equipos se cargaran dinamicamente aqui -->
  </section>

  <p id="equipoSuccess" class="success oculto">Equipo seleccionado correctamente.</p>
  <p id="equipoError" class="error oculto"></p>
  <p id="loadingEquipo" class="loading oculto">Cargando equipo...</p>

  <section id="equipoDetalles" class="equipo-box oculto">
    <p><strong>Serial</strong><br /><span id="equipoSerial"></span></p>
    <p><strong>Tipo</strong><br /><span id="equipoTipo"></span></p>
    <p><strong>Descripcion</strong><br /><span id="equipoDescripcion"></span></p>
  </section>
</article>
