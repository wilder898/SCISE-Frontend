<section class="layout">
    <aside class="sidebar">
    </aside>

    <main class="main">
        <header class="topbar">
            <section class="title">
                <h1>Registro de Salida de Equipo</h1>
            </section>

            <button class="btn-profile">Cerrar sesión</button>
        </header>

        <section class="cards">
            <article class="card">
                <header class="card-header">
                    <span class="icon">👤</span>
                    <h2>Escaneo Carnet</h2>
                </header>

                <section class="scan-area">
                    <input
                        type="text"
                        id="barcodeUser"
                        placeholder="Escanear codigo de barras del carnet..."
                    />
                </section>

                <p class="info" id="userInfo">Usuario:</p>
            </article>
            <article class="card">
                <header class="card-header">
                    <span class="icon">💻</span>
                    <h2>Escaneo Equipo</h2>
                </header>

                <input
                    type="text"
                    id="barcodeEquipo"
                    placeholder="Escanear codigo del equipo..."
                />

                <p class="info" id="equipoInfo">Equipo:</p>

                <p class="status" id="estadoEquipo">Estado:</p>
            </article>
        </section>

        <section class="actions">
            <button class="btn-cancelar" onclick="cancelar()">Cancelar</button>
            <button class="btn-registrar" id="btnSalida" disabled>
                Registrar ingreso
            </button>
        </section>

        <section class="info-panel">
            <h3>ℹ️ Instrucciones:</h3>
            <ul>
                <li>Escanea el código de barras del carnet del usuario.</li>
                <li>Se mostrarán los equipos disponibles del usuario.</li>
            </ul>
        </section>

        <footer id="message" class="message"></footer>
    </main>
</section>
