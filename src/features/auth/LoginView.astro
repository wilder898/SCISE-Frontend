<section class="login-view">
  <header class="login-header">
    <img
      class="logo"
      src="https://i.pinimg.com/474x/e8/62/92/e86292f703a81130c3e8aa86955aeabc.jpg"
      alt="Logo SENA"
    />
    <h1>Sistema SCISE</h1>
    <p class="subtitle">Sistema de Control de Ingreso y Salida de Equipos</p>
  </header>

  <section class="login-form-section">
    <form id="loginForm" class="login-form">
      <label class="form-field">
        <span class="form-label">Correo</span>
        <input class="form-input" type="email" id="username" placeholder="correo@scise.sena.edu.co" required />
      </label>

      <label class="form-field">
        <span class="form-label">Contrasena</span>
        <div class="password-input-wrap">
          <input class="form-input password-input" type="password" id="password" placeholder="Contrasena" required />
          <button
            class="password-toggle"
            type="button"
            id="togglePasswordButton"
            aria-label="Mostrar contrasena"
            aria-pressed="false"
          >
            <svg class="password-toggle__icon password-toggle__icon--show" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z" fill="none" stroke="currentColor" stroke-width="2" />
              <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2" />
            </svg>
            <svg class="password-toggle__icon password-toggle__icon--hide" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3 3l18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <path d="M10.6 10.7A3 3 0 0 0 13.4 13.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <path d="M6.7 6.8C4.2 8.4 2.7 11 2.7 11s3.5 6 9.3 6c1.7 0 3.2-.4 4.5-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <path d="M17.3 17.2C19.8 15.6 21.3 13 21.3 13S17.8 7 12 7c-1.7 0-3.2.4-4.5 1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </button>
        </div>
      </label>

      <button class="login-button" type="submit">Iniciar sesion</button>
    </form>

    <p class="loading-message" id="loading"></p>
    <p class="error-message" id="error"></p>
  </section>

  <footer class="login-footer">SCISE 2026 - Todos los derechos reservados</footer>
</section>
