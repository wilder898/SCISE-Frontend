<section>
  <section class="login-page">
    <main class="login-container">
      <header class="login-header">
        <img
          class="logo"
          src="https://i.pinimg.com/474x/e8/62/92/e86292f703a81130c3e8aa86955aeabc.jpg"
          alt="Logo SENA"
        />

        <h1>Sistema SCISE</h1>

        <p class="subtitle">
          Sistema de Control de Ingreso y Salida de Equipos
        </p>
      </header>

      <section class="login-form-section">
        <form id="loginForm" class="login-form">
          <label class="form-field">
            <input
              class="form-input"
              type="text"
              id="username"
              placeholder="Usuario"
              required
            />
          </label>

          <label class="form-field">
            <input
              class="form-input"
              type="password"
              id="password"
              placeholder="Contraseña"
              required
            />
          </label>

          <button class="login-button" type="submit"> Iniciar Sesión </button>
        </form>

        <p class="loading-message" id="loading"></p>
        <p class="error-message" id="error"></p>
      </section>

      <footer class="login-footer">
        © 2026 SENA - Todos los derechos reservados
      </footer>
    </main>
  </section>
</section>

<script>
  const users = [
    { username: "admin", password: "admin123", role: "admin" },
    { username: "user", password: "user123", role: "user" },
  ];

  const form = document.getElementById("loginForm");
  const usernameInput = document.getElementById("username");
  const passwordInput = document.getElementById("password");
  const loading = document.getElementById("loading");
  const error = document.getElementById("error");

  if (form && usernameInput && passwordInput && loading && error) {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      error.textContent = "";
      loading.textContent = "Validando credenciales...";

      const username = String(usernameInput.value || "").trim();
      const password = String(passwordInput.value || "");

      const match = users.find(
        (user) => user.username === username && user.password === password
      );

      if (!match) {
        loading.textContent = "";
        error.textContent = "Usuario o contraseña incorrectos.";
        return;
      }

      // Guardar sesión mínima para uso posterior (si se requiere).
      localStorage.setItem(
        "scise-session",
        JSON.stringify({
          username: match.username,
          role: match.role,
          loginAt: new Date().toISOString(),
        })
      );

      window.location.href = "/dashboard";
    });
  }
</script>
