<section class="login-view">
  <header class="login-header">
    <img class="logo" src="/favicon.svg" alt="Logo SCISE" />
    <h1>Sistema SCISE</h1>
    <p class="subtitle">Sistema de Control de Ingreso y Salida de Equipos</p>
  </header>

  <section class="login-form-section">
    <form id="loginForm" class="login-form">
      <label class="form-field">
        <span class="form-label">Usuario</span>
        <input class="form-input" type="text" id="username" placeholder="Usuario" required />
      </label>

      <label class="form-field">
        <span class="form-label">Contrasena</span>
        <input class="form-input" type="password" id="password" placeholder="Contrasena" required />
      </label>

      <button class="login-button" type="submit">Iniciar sesion</button>
    </form>

    <p class="loading-message" id="loading"></p>
    <p class="error-message" id="error"></p>
  </section>

  <footer class="login-footer">SCISE 2026 - Todos los derechos reservados</footer>
</section>
