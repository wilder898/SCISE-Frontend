<div class="config-modal" id="configNewUserModal" hidden>
  <div class="config-modal__overlay" data-close-modal="configNewUserModal"></div>

  <section
    class="config-modal__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="configNewUserModalTitle"
  >
    <div class="config-modal__header">
      <div>
        <h2 id="configNewUserModalTitle">Nuevo Usuario</h2>
        <p>Crea un acceso nuevo para la plataforma SCISE.</p>
      </div>

      <button
        class="config-modal__close"
        type="button"
        aria-label="Cerrar modal de nuevo usuario"
        data-close-modal="configNewUserModal"
      >
        x
      </button>
    </div>

    <form class="config-form" id="newUserForm">
      <div class="config-form-grid">
        <label class="config-field">
          <span>Nombre completo</span>
          <input id="newUserNombre" type="text" placeholder="Nombre completo" required />
        </label>

        <label class="config-field">
          <span>Email</span>
          <input id="newUserEmail" type="email" placeholder="correo@sena.edu.co" required />
        </label>

        <label class="config-field">
          <span>Documento de identidad</span>
          <input id="newUserDocumento" type="text" placeholder="Numero de documento" required />
        </label>

        <label class="config-field">
          <span>Rol</span>
          <select id="newUserRol" required>
            <option value="Administrador">Administrador</option>
            <option value="Seguridad">Seguridad</option>
            <option value="Operador">Operador</option>
            <option value="Consulta">Consulta</option>
          </select>
        </label>

        <label class="config-field config-field--full">
          <span>Departamento</span>
          <input id="newUserDepartamento" type="text" placeholder="Area o departamento" required />
        </label>
      </div>

      <div class="config-actions-row">
        <p class="config-form-note">El usuario se crea activo y con permisos iniciales segun su perfil del sistema.</p>
        <div class="config-modal__actions">
          <button class="config-button config-button--ghost" type="button" data-close-modal="configNewUserModal">
            Cancelar
          </button>
          <button class="config-button config-button--primary" type="submit">Crear usuario</button>
        </div>
      </div>
    </form>
  </section>
</div>
