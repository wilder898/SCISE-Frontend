<div class="config-modal" id="configPasswordModal" hidden>
  <div class="config-modal__overlay" data-close-modal="configPasswordModal"></div>

  <section
    class="config-modal__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="configPasswordModalTitle"
  >
    <div class="config-modal__header">
      <div>
        <h2 id="configPasswordModalTitle">Cambiar contraseña</h2>
        <p>Actualiza la contraseña de acceso del usuario seleccionado.</p>
      </div>

      <button
        class="config-modal__close"
        type="button"
        aria-label="Cerrar modal de contraseña"
        data-close-modal="configPasswordModal"
      >
        x
      </button>
    </div>

    <div class="password-target-card">
      <span class="password-target-card__eyebrow">Usuario seleccionado</span>
      <strong id="passwordTargetName">Ningún usuario seleccionado</strong>
      <p id="passwordTargetMeta">
        Usa la tabla de usuarios para elegir a quien deseas actualizar la contraseña.
      </p>
    </div>

    <form class="config-form" id="passwordResetForm">
      <div class="config-form-grid config-form-grid--single">
        <label class="config-field">
          <span>Nueva contraseña</span>
          <input id="passwordNueva" type="password" placeholder="Nueva contraseña" minlength="6" />
        </label>

        <label class="config-field">
          <span>Confirmar contraseña</span>
          <input
            id="passwordConfirmacion"
            type="password"
            placeholder="Confirma la nueva contraseña"
            minlength="6"
          />
        </label>

        <label class="config-check">
          <input id="togglePasswordVisibility" type="checkbox" />
          <span>Mostrar contraseñas</span>
        </label>
      </div>

      <div class="config-actions-row">
        <p class="config-form-note" id="passwordResetFeedback">
          La nueva contraseña debe tener al menos 6 caracteres.
        </p>
        <button class="config-button config-button--secondary" id="applyPasswordChange" type="submit">
          Actualizar contraseña
        </button>
      </div>
    </form>
  </section>
</div>

