<div class="user-modal-backdrop" id="newUserModalBackdrop" hidden>
  <section
    class="user-modal new-user-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="newUserModalTitle"
  >
    <header class="user-modal__header">
      <div>
        <p class="user-modal__eyebrow">Registro de usuario</p>
        <h2 id="newUserModalTitle">Nuevo Usuario</h2>
      </div>
      <button class="user-modal__close" id="closeNewUserModal" type="button" aria-label="Cerrar modal">
        x
      </button>
    </header>

    <section class="new-user-scan-card">
      <div class="new-user-scan-card__header">
        <div class="new-user-scan-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" fill="none" stroke="currentColor" stroke-width="2"></path>
            <path d="M4 21a8 8 0 0 1 16 0M5 7V4h3M19 7V4h-3M5 17v3h3M19 17v3h-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
          </svg>
        </div>
        <div>
          <h3>Escaneo de carnet</h3>
          <p>Escanea el carnet para registrar al usuario.</p>
        </div>
      </div>

      <div class="new-user-scan-card__actions">
        <label class="user-field">
          <span>Carnet</span>
          <input id="newUserCarnet" type="text" placeholder="Ej. SENA-23055" />
        </label>
        <button class="user-button user-button--primary" id="scanCarnetButton" type="button">
          <span id="scanCarnetButtonLabel">Usar Cámara</span>
        </button>
      </div>

      <div class="new-user-scan-card__status" id="scanStatusMessage">
        Listo para escanear el carnet.
      </div>

      <section id="newUserCameraScannerBox" class="camera-scanner oculto" aria-live="polite">
        <div class="camera-scanner__toolbar">
          <label class="camera-scanner__field">
            <span class="camera-scanner__label">Camara</span>
            <select id="newUserCameraDeviceSelect" class="camera-scanner__select">
              <option value="">Camara predeterminada</option>
            </select>
          </label>

          <button id="newUserCameraRefreshButton" class="camera-scanner__secondary-button" type="button">
            Actualizar
          </button>
        </div>

        <div class="camera-scanner__frame">
          <video
            id="newUserCameraScannerVideo"
            class="camera-scanner__video is-flipped"
            playsinline
            muted
            autoplay
          ></video>
          <div class="camera-scanner__overlay" aria-hidden="true">
            <span class="camera-scanner__guide"></span>
          </div>
        </div>

        <div class="camera-scanner__actions">
          <p class="camera-scanner__hint">
            Enfoca el código de barras del carnet dentro del recuadro para detectar el documento.
          </p>
          <div class="camera-scanner__buttons">
            <button
              id="newUserCameraCaptureButton"
              class="camera-scanner__capture-button"
              type="button"
            >
              Capturar y Escanear
            </button>
            <button
              id="newUserCameraScannerCloseButton"
              class="camera-scanner__close-button"
              type="button"
            >
              Cerrar Cámara
            </button>
          </div>
        </div>
      </section>

      <ul class="new-user-tips">
        <li>Puedes ingresar los datos manualmente si el lector no responde.</li>
      </ul>
    </section>

    <section class="user-modal__panel">
      <h3>Informacion personal</h3>

      <div class="new-user-form-grid">
        <label class="user-field">
          <span>Nombre</span>
          <input id="newUserNombre" type="text" />
          <small class="field-error" id="newUserNombreError"></small>
        </label>

        <label class="user-field">
          <span>Apellido</span>
          <input id="newUserApellido" type="text" />
          <small class="field-error" id="newUserApellidoError"></small>
        </label>

        <label class="user-field">
          <span>Cedula</span>
          <input id="newUserCedula" type="text" />
          <small class="field-error" id="newUserCedulaError"></small>
        </label>

        <label class="user-field">
          <span>Correo electronico</span>
          <input id="newUserEmail" type="email" />
          <small class="field-error" id="newUserEmailError"></small>
        </label>

        <label class="user-field">
          <span>Telefono</span>
          <input id="newUserTelefono" type="text" />
          <small class="field-error" id="newUserTelefonoError"></small>
        </label>

        <label class="user-field">
          <span>Rol</span>
          <select id="newUserRol">
            <option value="Aprendiz">Aprendiz</option>
            <option value="Instructor">Instructor</option>
            <option value="Coordinador">Coordinador</option>
          </select>
        </label>
      </div>
    </section>

    <footer class="user-modal__footer">
      <button class="user-button new-user-button--cancel" id="cancelNewUserModal" type="button">
        Cancelar
      </button>
      <button class="user-button new-user-button--create" id="createUserButton" type="button">
        Crear Usuario
      </button>
    </footer>
  </section>
</div>

