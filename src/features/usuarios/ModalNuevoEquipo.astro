<div class="user-modal-backdrop" id="newEquipmentModalBackdrop" hidden>
  <section
    class="user-modal equipment-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="newEquipmentModalTitle"
  >
    <header class="user-modal__header">
      <div>
        <p class="user-modal__eyebrow">Registro de equipos</p>
        <h2 id="newEquipmentModalTitle">Registrar Nuevo Equipo</h2>
      </div>
      <button class="user-modal__close" id="closeNewEquipmentModal" type="button" aria-label="Cerrar modal">
        x
      </button>
    </header>

    <section class="equipment-scan-card">
      <div class="equipment-scan-card__intro">
        <span class="equipment-scan-card__emoji" aria-hidden="true">[+]</span>
        <div>
          <h3>Escanear Carnet</h3>
          <p>Primero, escanea el carnet del usuario al que se asignara el equipo.</p>
        </div>
      </div>

      <div class="equipment-scan-card__actions">
        <label class="user-field">
          <span>Carnet o documento</span>
          <input
            id="equipmentUserLookup"
            type="text"
            placeholder="Escanea el carnet aqui"
            autocomplete="off"
          />
        </label>

        <button class="user-button user-button--primary" id="equipmentScanCarnetButton" type="button">
          <span id="equipmentScanCarnetButtonLabel">Usar Camara</span>
        </button>
      </div>

      <p id="equipmentScanStatusMessage" class="equipment-scan-card__status">
        Listo para escanear o ingresar el documento.
      </p>
      <p class="equipment-scan-card__hint">Tambien puedes escribir el documento y presionar Enter.</p>

      <section id="equipmentCameraScannerBox" class="camera-scanner oculto" aria-live="polite">
        <div class="camera-scanner__toolbar">
          <label class="camera-scanner__field">
            <span class="camera-scanner__label">Camara</span>
            <select id="equipmentCameraDeviceSelect" class="camera-scanner__select">
              <option value="">Camara predeterminada</option>
            </select>
          </label>

          <button id="equipmentCameraRefreshButton" class="camera-scanner__secondary-button" type="button">
            Actualizar
          </button>
        </div>

        <div class="camera-scanner__frame">
          <video
            id="equipmentCameraScannerVideo"
            class="camera-scanner__video is-flipped"
            playsinline
            muted
            autoplay
          ></video>
          <div class="camera-scanner__overlay" aria-hidden="true">
            <span class="camera-scanner__guide"></span>
          </div>
        </div>

        <div class="camera-scanner__actions">
          <p class="camera-scanner__hint">
            Enfoca el código de barras del carnet para identificar al usuario y habilitar el formulario.
          </p>
          <div class="camera-scanner__buttons">
            <button
              id="equipmentCameraCaptureButton"
              class="camera-scanner__capture-button"
              type="button"
            >
              Capturar y Escanear
            </button>
            <button
              id="equipmentCameraScannerCloseButton"
              class="camera-scanner__close-button"
              type="button"
            >
              Cerrar Cámara
            </button>
          </div>
        </div>
      </section>

      <p class="field-error equipment-scan-card__error" id="equipmentLookupError"></p>

      <div class="equipment-detected-user oculto" id="equipmentDetectedUser">
        <strong id="equipmentDetectedUserName"></strong>
        <span id="equipmentDetectedUserMeta"></span>
      </div>
    </section>

    <section class="user-modal__panel equipment-form-panel oculto" id="equipmentFormPanel">
      <div class="equipment-form-grid">
        <label class="user-field">
          <span>Serial *</span>
          <input id="newEquipmentSerial" type="text" placeholder="LAP-2024-0012345" />
          <small class="field-error" id="newEquipmentSerialError"></small>
        </label>

        <label class="user-field">
          <span>Tipo</span>
          <select id="newEquipmentTipo">
            <option value="Portatil">Portatil</option>
            <option value="Monitor">Monitor</option>
            <option value="Teclado">Teclado</option>
            <option value="Mouse">Mouse</option>
            <option value="Impresora">Impresora</option>
            <option value="Escaner">Escaner</option>
            <option value="Proyector">Proyector</option>
            <option value="Otro">Otro</option>
          </select>
        </label>

        <label class="user-field">
          <span>Marca</span>
          <input id="newEquipmentMarca" type="text" placeholder="Lenovo" />
        </label>

        <label class="user-field">
          <span>Modelo</span>
          <input id="newEquipmentModelo" type="text" placeholder="ThinkPad E15" />
        </label>
      </div>

      <label class="user-field">
        <span>Descripción</span>
        <textarea id="newEquipmentDescripcion" rows="4" placeholder="Detalles adicionales del equipo"></textarea>
      </label>
    </section>

    <footer class="user-modal__footer">
      <button class="user-button user-button--ghost" id="cancelNewEquipmentModal" type="button">
        Cancelar
      </button>
      <button class="user-button user-button--ghost" id="resetEquipmentUserButton" type="button">
        Escanear Otro Carnet
      </button>
      <button class="user-button user-button--secondary" id="createEquipmentButton" type="button">
        Registrar Equipo
      </button>
    </footer>
  </section>
</div>

