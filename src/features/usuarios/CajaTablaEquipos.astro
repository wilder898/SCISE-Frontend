<section class="users-table-card users-equipment-card">
  <div class="users-table-header">
    <div>
      <h3>Equipos Registrados</h3>
      <p>Equipos asignados a usuarios operativos dentro del sistema.</p>
    </div>
    <div class="users-equipment-total">
      Total: <strong id="equipmentTableCount">0</strong>
    </div>
  </div>

  <div class="users-table-wrap">
    <table class="users-table users-equipment-table">
      <thead>
        <tr>
          <th>Serial</th>
          <th>Equipo</th>
          <th>Tipo</th>
          <th>Usuario asignado</th>
          <th>Estado actual</th>
        </tr>
      </thead>
      <tbody id="equipmentTableBody"></tbody>
    </table>
  </div>

  <div class="users-empty-state" id="equipmentEmptyState">
    Aún no hay equipos registrados desde este módulo.
  </div>
</section>
