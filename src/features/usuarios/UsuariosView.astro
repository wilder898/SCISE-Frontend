  async function createEquipmentAsync() {
    if (!validateEquipmentForm()) {
      return;
    }

    const serial = newEquipmentFields.serial instanceof HTMLInputElement ? newEquipmentFields.serial.value.trim() : "";
    const tipo = newEquipmentFields.tipo instanceof HTMLSelectElement ? newEquipmentFields.tipo.value : "Otro";
    const marca = newEquipmentFields.marca instanceof HTMLInputElement ? newEquipmentFields.marca.value.trim() : "";
    const modelo = newEquipmentFields.modelo instanceof HTMLInputElement ? newEquipmentFields.modelo.value.trim() : "";
    const descripcion =
      newEquipmentFields.descripcion instanceof HTMLTextAreaElement
        ? newEquipmentFields.descripcion.value.trim()
        : "";
    const nombreGenerado = [marca, modelo].filter(Boolean).join(" ").trim() || serial;

    try {
      createEquipmentButton?.setAttribute("disabled", "true");

      const equipoCreado = await createEquipmentInApi({
        serial,
        nombre: nombreGenerado,
        tipo_equipo: tipo,
        descripcion,
        codigo_barras_equipo: serial,
        estudiante_id: state.equipmentModalUserId,
      });

      if (!equipoCreado) {
        return;
      }

      await hydrateUsersAndEquipments();
      await loadEquipmentTable();
      closeEquipmentModal();
    } catch (error) {
      if (equipmentLookupError) {
        equipmentLookupError.textContent =
          error instanceof Error ? error.message : "No fue posible registrar el equipo.";
      }
    } finally {
      createEquipmentButton?.removeAttribute("disabled");
    }
  }

  window.addEventListener("scise:users-modal-scanner-detected", (event) => {
    const customEvent = event;
    const detail = customEvent instanceof CustomEvent ? customEvent.detail : null;
    const target = String(detail?.target || "");
    const value = String(detail?.value || "").trim();

    if (!value) {
      return;
    }

    if (target === "new-user") {
      handleDetectedCarnetForNewUser(value);
      return;
    }

    if (target === "equipment-user") {
      if (equipmentUserLookup instanceof HTMLInputElement) {
        equipmentUserLookup.value = value;
      }
      void detectEquipmentUser();
    }
  });

  if (sessionRoleBadge) {
    const badgeValue = sessionRoleBadge.querySelector("strong");

    if (badgeValue) {
      badgeValue.textContent =
        sessionRole === "admin" ? "Administrador" : "Usuario";
    }
  }

  searchInput?.addEventListener("input", () => {
    state.userPage = 1;
    renderTable();
  });
  roleFilter?.addEventListener("change", () => {
    state.userPage = 1;
    renderTable();
  });
  statusFilter?.addEventListener("change", () => {
    state.userPage = 1;
    renderTable();
  });
  dateFilter?.addEventListener("change", () => {
    state.userPage = 1;
    renderTable();
  });

  equipmentSearchInput?.addEventListener("input", () => {
    if (equipmentSearchDebounce !== null) {
      window.clearTimeout(equipmentSearchDebounce);
    }

    equipmentSearchDebounce = window.setTimeout(() => {
      state.equipmentPage = 1;
      loadEquipmentTable();
    }, 300);
  });
  equipmentTypeFilter?.addEventListener("change", () => {
    state.equipmentPage = 1;
    loadEquipmentTable();
  });
  equipmentStatusFilter?.addEventListener("change", () => {
    state.equipmentPage = 1;
    loadEquipmentTable();
  });

  clearFiltersButton?.addEventListener("click", () => {
    if (searchInput) searchInput.value = "";
    if (roleFilter) roleFilter.value = "";
    if (statusFilter) statusFilter.value = "";
    if (dateFilter) dateFilter.value = "";
    state.userPage = 1;
    renderTable();
  });

  clearEquipmentFiltersButton?.addEventListener("click", () => {
    if (equipmentSearchInput) equipmentSearchInput.value = "";
    if (equipmentTypeFilter) equipmentTypeFilter.value = "";
    if (equipmentStatusFilter) equipmentStatusFilter.value = "";
    state.equipmentPage = 1;
    loadEquipmentTable();
  });

  exportCsvButton?.addEventListener("click", exportCsv);
  exportPdfButton?.addEventListener("click", () => {
    alert("La exportacion PDF queda lista para implementar.");
  });

  tableBody?.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target.closest("button") : null;

    if (!(target instanceof HTMLButtonElement)) {
      return;
    }

    const userId = Number(target.dataset.userId || 0);
    const action = target.dataset.action;

    if (action === "edit") {
      openModal(userId);
    }

    if (action === "toggle-status") {
      toggleStatus(userId);
    }

  });

  equipmentForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    void buscarEquiposParaAsociar();
  });

  equipmentSearchResults?.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target.closest("button") : null;

    if (!(target instanceof HTMLButtonElement)) {
      return;
    }

    if (target.dataset.action !== "associate-equipment") {
      return;
    }

    const equipoId = Number(target.dataset.equipoId || 0);
    if (!equipoId) {
      return;
    }

    void asociarEquipoAEstudiante(equipoId);
  });

  usersPagination?.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target.closest("button") : null;

    if (!(target instanceof HTMLButtonElement) || target.dataset.pageKey !== "users") {
      return;
    }

    const totalPages = Math.max(1, Math.ceil(getFilteredUsers().length / USERS_PAGE_SIZE));
    const nextPage = Number(target.dataset.page || state.userPage);
    state.userPage = Math.max(1, Math.min(nextPage, totalPages));
    renderTable();
  });

  equipmentPagination?.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target.closest("button") : null;

    if (!(target instanceof HTMLButtonElement) || target.dataset.pageKey !== "equipments") {
      return;
    }

    const totalPages = Math.max(1, Math.ceil(state.equipments.length / EQUIPMENTS_PAGE_SIZE));
    const nextPage = Number(target.dataset.page || state.equipmentPage);
    state.equipmentPage = Math.max(1, Math.min(nextPage, totalPages));
    renderEquipmentTable();
  });

  closeUserModal?.addEventListener("click", closeModal);
  cancelUserModal?.addEventListener("click", closeModal);
  saveUserButton?.addEventListener("click", () => {
    void saveModalChanges();
  });

  modalBackdrop?.addEventListener("click", (event) => {
    if (event.target === modalBackdrop) {
      closeModal();
    }
  });

  openNewUserModal?.addEventListener("click", openCreateModal);
  openRegisterEquipmentButton?.addEventListener("click", openRegisterEquipmentFlow);
  closeNewUserModal?.addEventListener("click", closeCreateModal);
  cancelNewUserModal?.addEventListener("click", closeCreateModal);
  createUserButton?.addEventListener("click", () => {
    void createUser();
  });
  closeNewEquipmentModal?.addEventListener("click", closeEquipmentModal);
  cancelNewEquipmentModal?.addEventListener("click", closeEquipmentModal);
  resetEquipmentUserButton?.addEventListener("click", resetEquipmentForm);
  createEquipmentButton?.addEventListener("click", createEquipment);

  equipmentUserLookup?.addEventListener("keypress", (event) => {
    if (event.key === "Enter") {
      event.preventDefault();
      detectEquipmentUser();
    }
  });

  Object.entries(newUserFields).forEach(([key, node]) => {
    if (!(node instanceof HTMLInputElement) && !(node instanceof HTMLSelectElement)) {
      return;
    }

    node.addEventListener("input", () => {
      if (key in newUserErrors) {
        validateNewUserForm();
      }

      if (key === "carnet" && scanStatusMessage) {
        setNewUserScanStatus(
          node.value.trim()
            ? "Carnet detectado. Verifica o completa los datos del usuario."
            : "Listo para escanear el carnet.",
          node.value.trim() ? "is-success" : ""
        );
      }
    });
  });

  newUserModalBackdrop?.addEventListener("click", (event) => {
    if (event.target === newUserModalBackdrop) {
      closeCreateModal();
    }
  });

  newEquipmentModalBackdrop?.addEventListener("click", (event) => {
    if (event.target === newEquipmentModalBackdrop) {
      closeEquipmentModal();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      if (modalBackdrop && !modalBackdrop.hidden) {
        closeModal();
      }

      if (newUserModalBackdrop && !newUserModalBackdrop.hidden) {
        closeCreateModal();
      }
    }
  });

  hydrateUsersAndEquipments()
    .then(() => loadEquipmentTable())
    .catch((error) => {
      alert(error instanceof Error ? error.message : "No fue posible cargar los usuarios.");
    });

  const routeParams = new URLSearchParams(window.location.search);

  if (routeParams.get("new") === "true") {
    openCreateModal();
  }

  if (routeParams.get("equipment") === "true") {
    openRegisterEquipmentFlow();
  }
</script>

<script>
  import { ScannerController } from "../../lib/scanner/scanner-controller";
  import type { ScannerCameraDevice } from "../../lib/scanner/scanner-types";

  interface UsersModalScannerConfig {
    target: "new-user" | "equipment-user";
    inputId: string;
    buttonId: string;
    buttonLabelId: string;
    statusId: string;
    statusClassName: string;
    boxId: string;
    videoId: string;
    deviceSelectId: string;
    refreshButtonId: string;
    captureButtonId: string;
    closeButtonId: string;
    unsupportedMessage: string;
    detectedMessage: string;
  }

  function mountUsersModalScanner(config: UsersModalScannerConfig) {
    const inputElement = document.getElementById(config.inputId);
    const buttonElement = document.getElementById(config.buttonId);
    const buttonLabelElement = document.getElementById(config.buttonLabelId);
    const statusElement = document.getElementById(config.statusId);
    const scannerBoxElement = document.getElementById(config.boxId);
    const videoElement = document.getElementById(config.videoId);
    const deviceSelectElement = document.getElementById(config.deviceSelectId);
    const refreshButtonElement = document.getElementById(config.refreshButtonId);
    const captureButtonElement = document.getElementById(config.captureButtonId);
    const closeButtonElement = document.getElementById(config.closeButtonId);

    if (!(inputElement instanceof HTMLInputElement) || !(videoElement instanceof HTMLVideoElement)) {
      return;
    }

    let isCameraActive = false;
    let selectedCameraDeviceId = "";
    let availableCameraDevices: ScannerCameraDevice[] = [];

    const controller = new ScannerController({
      inputElement,
      videoElement,
      facingMode: "environment",
      onDetected: () => {
        hideScanner();
        updateStatus(config.detectedMessage, "success");
        window.dispatchEvent(
          new CustomEvent("scise:users-modal-scanner-detected", {
            detail: {
              target: config.target,
              value: inputElement.value.trim(),
            },
          })
        );
      },
      onError: (payload) => {
        hideScanner();
        updateStatus(payload.message, "error");
      },
      onStatusChange: (payload) => {
        const tone =
          payload.status === "detected"
            ? "success"
            : payload.status === "error"
              ? "error"
              : "info";
        updateStatus(payload.message, tone);

        if (payload.status === "ready" || payload.status === "scanning") {
          showScanner();
          return;
        }

        if (payload.status === "stopped") {
          hideScanner();
        }
      },
    });

    function updateButtonState() {
      if (!(buttonElement instanceof HTMLButtonElement)) {
        return;
      }

      buttonElement.setAttribute(
        "aria-label",
        isCameraActive ? "Cerrar camara del lector" : "Usar camara para escanear el carnet"
      );
      if (buttonLabelElement) {
        buttonLabelElement.textContent = isCameraActive ? "Cerrar Camara" : "Usar Camara";
      }
    }

    function updateStatus(message: string, tone: "info" | "error" | "success" = "info") {
      if (!(statusElement instanceof HTMLElement)) {
        return;
      }

      statusElement.textContent = message;
      statusElement.classList.remove("is-success", "is-error", "is-scanning");

      if (config.statusClassName) {
        statusElement.className = config.statusClassName;
      }

      if (tone === "success") {
        statusElement.classList.add("is-success");
      } else if (tone === "error") {
        statusElement.classList.add("is-error");
      } else if (tone === "info" && isCameraActive) {
        statusElement.classList.add("is-scanning");
      }
    }

    function renderCameraDevices() {
      if (!(deviceSelectElement instanceof HTMLSelectElement)) {
        return;
      }

      const options = [
        `<option value="">Camara predeterminada</option>`,
        ...availableCameraDevices.map(
          (device) =>
            `<option value="${device.id}" ${device.id === selectedCameraDeviceId ? "selected" : ""}>${device.label}</option>`
        ),
      ];

      deviceSelectElement.innerHTML = options.join("");
      if (!selectedCameraDeviceId) {
        deviceSelectElement.value = "";
      }
    }

    async function refreshCameraDevices() {
      availableCameraDevices = await ScannerController.listCameraDevices();

      if (
        selectedCameraDeviceId &&
        !availableCameraDevices.some((device) => device.id === selectedCameraDeviceId)
      ) {
        selectedCameraDeviceId = "";
        controller.setCameraDevice(null);
      }

      renderCameraDevices();
    }

    function showScanner() {
      scannerBoxElement?.classList.remove("oculto");
      isCameraActive = true;
      updateButtonState();
    }

    function hideScanner() {
      scannerBoxElement?.classList.add("oculto");
      isCameraActive = false;
      updateButtonState();
    }

    async function startScanner() {
      if (!ScannerController.isCameraSupported()) {
        updateStatus(config.unsupportedMessage, "error");
        return;
      }

      await refreshCameraDevices();
      controller.setCameraDevice(selectedCameraDeviceId || null);
      showScanner();
      updateStatus("Preparando camara para leer el carnet...", "info");
      await controller.startCamera();
      await refreshCameraDevices();
    }

    function stopScanner(message = "") {
      controller.stopCamera();
      hideScanner();
      if (message) {
        updateStatus(message, "info");
        return;
      }
    }

    async function restartForDeviceChange() {
      if (!isCameraActive) {
        return;
      }

      updateStatus("Cambiando de camara...", "info");
      controller.stopCamera();
      hideScanner();
      controller.setCameraDevice(selectedCameraDeviceId || null);
      await startScanner();
    }

    buttonElement?.addEventListener("click", () => {
      if (isCameraActive) {
        stopScanner("Camara cerrada. Puedes seguir con el ingreso manual.");
        return;
      }

      void startScanner();
    });

    closeButtonElement?.addEventListener("click", () => {
      stopScanner("Camara cerrada. Puedes seguir con el ingreso manual.");
    });

    refreshButtonElement?.addEventListener("click", () => {
      void refreshCameraDevices();
    });

    captureButtonElement?.addEventListener("click", () => {
      void controller.captureAndDetect();
    });

    deviceSelectElement?.addEventListener("change", () => {
      if (!(deviceSelectElement instanceof HTMLSelectElement)) {
        return;
      }

      selectedCameraDeviceId = deviceSelectElement.value;
      controller.setCameraDevice(selectedCameraDeviceId || null);
      void restartForDeviceChange();
    });

    window.addEventListener("scise:users-modal-scanner-stop", (event) => {
      const detail = event instanceof CustomEvent ? event.detail : null;
      if (!detail?.target || detail.target === config.target) {
        stopScanner();
      }
    });

    window.addEventListener("pagehide", () => {
      stopScanner();
    });

    updateButtonState();
    void refreshCameraDevices();
  }

  mountUsersModalScanner({
    target: "new-user",
    inputId: "newUserCarnet",
    buttonId: "scanCarnetButton",
    buttonLabelId: "scanCarnetButtonLabel",
    statusId: "scanStatusMessage",
    statusClassName: "new-user-scan-card__status",
    boxId: "newUserCameraScannerBox",
    videoId: "newUserCameraScannerVideo",
    deviceSelectId: "newUserCameraDeviceSelect",
    refreshButtonId: "newUserCameraRefreshButton",
    captureButtonId: "newUserCameraCaptureButton",
    closeButtonId: "newUserCameraScannerCloseButton",
    unsupportedMessage: "Este navegador no permite usar la camara para leer el carnet.",
    detectedMessage: "Documento detectado. Verificando datos del usuario...",
  });

  mountUsersModalScanner({
    target: "equipment-user",
    inputId: "equipmentUserLookup",
    buttonId: "equipmentScanCarnetButton",
    buttonLabelId: "equipmentScanCarnetButtonLabel",
    statusId: "equipmentScanStatusMessage",
    statusClassName: "equipment-scan-card__status",
    boxId: "equipmentCameraScannerBox",
    videoId: "equipmentCameraScannerVideo",
    deviceSelectId: "equipmentCameraDeviceSelect",
    refreshButtonId: "equipmentCameraRefreshButton",
    captureButtonId: "equipmentCameraCaptureButton",
    closeButtonId: "equipmentCameraScannerCloseButton",
    unsupportedMessage: "Este navegador no permite usar la camara para leer el carnet.",
    detectedMessage: "Documento detectado. Consultando usuario...",
  });
</script>
