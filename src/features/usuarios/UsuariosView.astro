  async function lookupStudentByDocument(documento) {
    const token = getAuthToken();
    if (!token) {
      handleUnauthorized();
      return null;
    }

    const response = await fetch(
      `${API_BASE_URL}/estudiantes/by-documento/${encodeURIComponent(documento)}`,
      {
        method: "GET",
        headers: {
          Authorization: `Bearer ${token}`,
        },
      }
    );

    if (response.status === 401) {
      const payload = await response.json().catch(() => ({}));
      handleUnauthorized(typeof payload?.detail === "string" ? payload.detail : undefined);
      return null;
    }

    if (!response.ok) {
      const payload = await response.json().catch(() => ({}));
      throw new Error(
        typeof payload?.detail === "string" && payload.detail.trim()
          ? payload.detail
          : "No encontramos un usuario con ese carnet o documento."
      );
    }

    return await response.json();
  }

  async function createEquipmentInApi(payload) {
    const token = getAuthToken();
    if (!token) {
      handleUnauthorized();
      return null;
    }

    const response = await fetch(`${API_BASE_URL}/equipos`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${token}`,
      },
      body: JSON.stringify(payload),
    });

    if (response.status === 401) {
      const unauthorizedPayload = await response.json().catch(() => ({}));
      handleUnauthorized(typeof unauthorizedPayload?.detail === "string" ? unauthorizedPayload.detail : undefined);
      return null;
    }

    if (!response.ok) {
      const payloadError = await response.json().catch(() => ({}));
      throw new Error(
        typeof payloadError?.detail === "string" && payloadError.detail.trim()
          ? payloadError.detail
          : "No fue posible registrar el equipo."
      );
    }

    return await response.json();
  }

  function buildEquipmentQuery(filters) {
    const query = new URLSearchParams();

    if (filters.q) {
      query.set("q", filters.q);
    }
    if (filters.tipo) {
      query.set("tipo", filters.tipo);
    }
    if (filters.estado) {
      query.set("estado", filters.estado);
    }

    query.set("skip", String(filters.skip));
    query.set("limit", String(filters.limit));
    return query;
  }

  async function fetchEquipmentListFromApi(filters) {
    const token = getAuthToken();
    if (!token) {
      handleUnauthorized();
      return null;
    }

    const response = await fetch(`${API_BASE_URL}/equipos?${buildEquipmentQuery(filters).toString()}`, {
      method: "GET",
      headers: {
        Authorization: `Bearer ${token}`,
      },
    });

    if (response.status === 401) {
      const payload = await response.json().catch(() => ({}));
      handleUnauthorized(typeof payload?.detail === "string" ? payload.detail : undefined);
      return null;
    }

    if (!response.ok) {
      const payloadError = await response.json().catch(() => ({}));
      throw new Error(
        typeof payloadError?.detail === "string" && payloadError.detail.trim()
          ? payloadError.detail
          : "No fue posible consultar equipos."
      );
    }

    const payload = await response.json().catch(() => ({}));
    return {
      data: Array.isArray(payload?.data) ? payload.data : [],
      meta: payload?.meta && typeof payload.meta === "object"
        ? {
            total: Number(payload.meta.total ?? 0),
            skip: Number(payload.meta.skip ?? 0),
            limit: Number(payload.meta.limit ?? filters.limit),
            has_next: Boolean(payload.meta.has_next ?? false),
          }
        : {
            total: 0,
            skip: filters.skip,
            limit: filters.limit,
            has_next: false,
          },
    };
  }

  async function fetchAllEquipmentFromApi(filters) {
    const allData = [];
    let skip = 0;
    let total = 0;

    while (true) {
      const response = await fetchEquipmentListFromApi({
        ...filters,
        skip,
        limit: EQUIPMENT_PAGE_LIMIT,
      });

      if (!response) {
        return null;
      }

      const pageData = Array.isArray(response.data) ? response.data : [];
      allData.push(...pageData);
      total = Number(response.meta?.total ?? total ?? allData.length);

      if (!response.meta?.has_next || !pageData.length) {
        break;
      }

      skip += Number(response.meta?.limit || EQUIPMENT_PAGE_LIMIT);
    }

    return {
      data: allData,
      meta: {
        total,
        skip: 0,
        limit: allData.length || EQUIPMENT_PAGE_LIMIT,
        has_next: false,
      },
    };
  }

  async function loadEquipmentTable() {
    const requestId = ++state.equipmentRequestId;
    state.equipmentLoading = true;
    state.equipmentErrorMessage = "";
    renderEquipmentTable();

    try {
      const filters = getEquipmentFilters();
      const response = await fetchAllEquipmentFromApi(filters);

      if (!response || requestId !== state.equipmentRequestId) {
        return;
      }

      state.equipments = response.data.map(mapEquipmentItemFromApi);
      state.equipmentMeta = response.meta;
    } catch (error) {
      if (requestId !== state.equipmentRequestId) {
        return;
      }

      state.equipments = [];
      state.equipmentMeta = {
        total: 0,
        skip: 0,
        limit: EQUIPMENT_PAGE_LIMIT,
        has_next: false,
      };
      state.equipmentErrorMessage =
        error instanceof Error ? error.message : "No fue posible cargar la tabla de equipos.";
    } finally {
      if (requestId === state.equipmentRequestId) {
        state.equipmentLoading = false;
        renderEquipmentTable();
      }
    }
  }

  async function detectEquipmentUser() {
    if (!(equipmentUserLookup instanceof HTMLInputElement)) {
      return;
    }

    const lookupValue = equipmentUserLookup.value.trim();
    if (!lookupValue) {
      return;
    }

    try {
      setEquipmentScanStatus("Consultando usuario por documento...", "");
      const estudiante = await lookupStudentByDocument(lookupValue);
      if (!estudiante) {
        return;
      }

      state.equipmentModalUserId = estudiante.id;
      state.equipmentModalUserLookup = estudiante;

      const localUser = findUserByCarnet(lookupValue) || state.users.find((user) => user.cedula === estudiante.documento);
      const displayName = localUser ? getFullName(localUser) : estudiante.nombre;

      if (equipmentLookupError) {
        equipmentLookupError.textContent = "";
      }
      if (equipmentDetectedUserName) {
        equipmentDetectedUserName.textContent = `Usuario detectado: ${displayName}`;
      }
      if (equipmentDetectedUserMeta) {
        equipmentDetectedUserMeta.textContent = `Carnet/Documento: ${lookupValue}`;
      }
      equipmentDetectedUser?.classList.remove("oculto");
      equipmentFormPanel?.classList.remove("oculto");
      setEquipmentScanStatus("Usuario identificado correctamente.", "is-success");
    } catch (error) {
      state.equipmentModalUserId = null;
      state.equipmentModalUserLookup = null;
      equipmentDetectedUser?.classList.add("oculto");
      equipmentFormPanel?.classList.add("oculto");
      setEquipmentScanStatus("No se pudo identificar el usuario con ese documento.", "is-error");
      if (equipmentLookupError) {
        equipmentLookupError.textContent =
          error instanceof Error ? error.message : "No encontramos un usuario con ese carnet o documento.";
      }
    }
  }

