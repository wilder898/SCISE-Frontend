  function handleDetectedCarnetForNewUser(documento) {
    const detectedValue = String(documento || "").trim();
    if (!detectedValue) {
      setNewUserScanStatus("No se detecto un documento valido en el carnet.", "is-error");
      return;
    }

    newUserFields.carnet.value = detectedValue;
    newUserFields.cedula.value = detectedValue;
    newUserFields.carnet.dispatchEvent(new Event("input", { bubbles: true }));
    newUserFields.cedula.dispatchEvent(new Event("input", { bubbles: true }));

    const existingUser =
      findUserByCarnet(detectedValue) ||
      state.users.find((user) => String(user.cedula || "").trim() === detectedValue) ||
      null;

    if (existingUser) {
      fillNewUserFormFromExisting(existingUser);
      setNewUserScanStatus(
        "Documento detectado. Se cargaron los datos existentes para validacion.",
        "is-success"
      );
      return;
    }

    setNewUserScanStatus(
      "Documento detectado. Completa los datos restantes para crear el usuario.",
      "is-success"
    );
  }

