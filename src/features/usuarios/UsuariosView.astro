  function validateNewUserForm() {
    let isValid = true;
    const values = {
      carnet: newUserFields.carnet.value.trim(),
      nombre: newUserFields.nombre.value.trim(),
      apellido: newUserFields.apellido.value.trim(),
      cedula: newUserFields.cedula.value.trim(),
      email: newUserFields.email.value.trim(),
      telefono: newUserFields.telefono.value.trim(),
    };

    setFieldError("nombre", values.nombre ? "" : "El nombre es obligatorio.");
    setFieldError("apellido", values.apellido ? "" : "El apellido es obligatorio.");
    setFieldError("cedula", values.cedula ? "" : "La cedula es obligatoria.");
    setFieldError("telefono", values.telefono ? "" : "El telefono es obligatorio.");

    if (!values.email) {
      setFieldError("email", "El email es obligatorio.");
      isValid = false;
    } else if (!validateEmail(values.email)) {
      setFieldError("email", "Ingresa un email valido.");
      isValid = false;
    } else {
      setFieldError("email", "");
    }

    if (!values.nombre) isValid = false;
    if (!values.apellido) isValid = false;
    if (!values.cedula) isValid = false;
    if (!values.telefono) isValid = false;

    if (!values.carnet) {
      if (scanStatusMessage) {
        scanStatusMessage.textContent = "Debes escanear o ingresar un carnet antes de crear.";
        scanStatusMessage.className = "new-user-scan-card__status is-error";
      }
      isValid = false;
    }

    return isValid;
  }

