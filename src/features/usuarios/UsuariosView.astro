  async function saveModalChanges() {
    const user = getSelectedUser();

    if (!user) {
      return;
    }

    try {
      saveUserButton?.setAttribute("disabled", "true");
      const isAdmin = sessionRole === "admin";

      const payload = await apiRequest(
        `/estudiantes/${encodeURIComponent(user.id)}`,
        {
          method: "PATCH",
          body: {
            nombre: [modalFields.nombre.value.trim(), modalFields.apellido.value.trim()]
              .filter(Boolean)
              .join(" ")
              .trim(),
            documento: modalFields.cedula.value.trim(),
            codigo_barras: modalFields.carnet.value.trim(),
            email: modalFields.email.value.trim() || null,
            celular: modalFields.telefono.value.trim() || null,
            ...(isAdmin ? { rol: modalFields.rol.value } : {}),
            ...(isAdmin ? { estado: toBackendStatus(modalFields.estado.value) } : {}),
          },
        },
        "No fue posible actualizar el estudiante."
      );

      if (!payload) {
        return;
      }

      const nextUser = mapEstudianteToUser(payload);
      nextUser.equipos = [...user.equipos];
      const userIndex = state.users.findIndex((item) => item.id === user.id);
      if (userIndex >= 0) {
        state.users[userIndex] = nextUser;
      }

      renderTable();
      renderEquipmentTable();
      closeModal();
    } catch (error) {
      alert(error instanceof Error ? error.message : "No fue posible actualizar el usuario.");
    } finally {
      saveUserButton?.removeAttribute("disabled");
    }
  }

