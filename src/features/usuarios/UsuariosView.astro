---
import CajaPanelInicial from "./CajaPanelInicial.astro";
import CajaFiltros from "./CajaFiltros.astro";
import CajaTablaUsuarios from "./CajaTablaUsuarios.astro";
import CajaTablaEquipos from "./CajaTablaEquipos.astro";
import CajaInformacion from "./CajaInformacion.astro";
import UserEditModal from "./UserEditModal.astro";
import NewUserModal from "./NewUserModal.astro";
import ModalNuevoEquipo from "./ModalNuevoEquipo.astro";

const apiBaseUrl = (import.meta.env.PUBLIC_API_BASE_URL || "http://localhost:8000/api/v1").replace(/\/$/, "");

---

<section class="users-page">
  <CajaPanelInicial />
  <CajaFiltros />
  <CajaTablaUsuarios />
  <CajaTablaEquipos />
  <CajaInformacion />

  <UserEditModal />
  <NewUserModal />
  <ModalNuevoEquipo />
</section>

<script define:vars={{ apiBaseUrl }}>
  const API_BASE_URL = apiBaseUrl;
  function readSession() {
    try {
      const raw = localStorage.getItem("scise-session");
      if (!raw) {
        return {};
      }

      const parsed = JSON.parse(raw);
      return parsed && typeof parsed === "object" ? parsed : {};
    } catch {
      return {};
    }
  }

  function resolveSessionRole(session) {
    const roleValue = String(session?.role || session?.rol || "").toLowerCase();
    const backendRole = String(session?.roleBackend || "").toUpperCase();

    if (roleValue === "admin" || roleValue === "administrador" || backendRole === "ADMINISTRADOR") {
      return "admin";
    }

    return "user";
  }

  const sessionData = readSession();
  const sessionRole = resolveSessionRole(sessionData);

  const state = {
    users: [],
    usersLoading: false,
    userErrorMessage: "",
    userPage: 1,
    equipments: [],
    equipmentMeta: {
      total: 0,
      skip: 0,
      limit: 100,
      has_next: false,
    },
    equipmentLoading: false,
    equipmentErrorMessage: "",
    equipmentPage: 1,
    equipmentRequestId: 0,
    selectedUserId: null,
    equipmentSearchResults: [],
    equipmentModalUserId: null,
    equipmentModalUserLookup: null,
  };

  const tableBody = document.getElementById("usersTableBody");
  const emptyState = document.getElementById("usersEmptyState");
  const usersPagination = document.getElementById("usersPagination");
  const sessionRoleBadge = document.getElementById("sessionRoleBadge");
  const searchInput = document.getElementById("searchInput");
  const roleFilter = document.getElementById("roleFilter");
  const statusFilter = document.getElementById("statusFilter");
  const dateFilter = document.getElementById("dateFilter");
  const clearFiltersButton = document.getElementById("clearFiltersButton");
  const exportCsvButton = document.getElementById("exportCsvButton");
  const exportPdfButton = document.getElementById("exportPdfButton");

  const modalBackdrop = document.getElementById("userModalBackdrop");
  const closeUserModal = document.getElementById("closeUserModal");
  const cancelUserModal = document.getElementById("cancelUserModal");
  const saveUserButton = document.getElementById("saveUserButton");
  const equipmentForm = document.getElementById("equipmentForm");
  const equipmentList = document.getElementById("equipmentList");
  const equipmentSearchResults = document.getElementById("equipmentSearchResults");
  const permissionMessage = document.getElementById("userPermissionMessage");

  const openNewUserModal = document.getElementById("openNewUserModal");
  const openRegisterEquipmentButton = document.getElementById("openRegisterEquipmentButton");
  const newUserModalBackdrop = document.getElementById("newUserModalBackdrop");
  const closeNewUserModal = document.getElementById("closeNewUserModal");
  const cancelNewUserModal = document.getElementById("cancelNewUserModal");
  const createUserButton = document.getElementById("createUserButton");
  const scanStatusMessage = document.getElementById("scanStatusMessage");
  const newEquipmentModalBackdrop = document.getElementById("newEquipmentModalBackdrop");
  const closeNewEquipmentModal = document.getElementById("closeNewEquipmentModal");
  const cancelNewEquipmentModal = document.getElementById("cancelNewEquipmentModal");
  const resetEquipmentUserButton = document.getElementById("resetEquipmentUserButton");
  const createEquipmentButton = document.getElementById("createEquipmentButton");
  const equipmentScanStatusMessage = document.getElementById("equipmentScanStatusMessage");
  const equipmentUserLookup = document.getElementById("equipmentUserLookup");
  const equipmentLookupError = document.getElementById("equipmentLookupError");
  const equipmentDetectedUser = document.getElementById("equipmentDetectedUser");
  const equipmentDetectedUserName = document.getElementById("equipmentDetectedUserName");
  const equipmentDetectedUserMeta = document.getElementById("equipmentDetectedUserMeta");
  const equipmentFormPanel = document.getElementById("equipmentFormPanel");
  const equipmentTableBody = document.getElementById("equipmentTableBody");
  const equipmentTableCount = document.getElementById("equipmentTableCount");
  const equipmentEmptyState = document.getElementById("equipmentEmptyState");
  const equipmentPagination = document.getElementById("equipmentPagination");
  const equipmentSearchInput = document.getElementById("equipmentSearchInput");
  const equipmentTypeFilter = document.getElementById("equipmentTypeFilter");
  const equipmentStatusFilter = document.getElementById("equipmentStatusFilter");
  const clearEquipmentFiltersButton = document.getElementById("clearEquipmentFiltersButton");

  const modalFields = {
    nombre: document.getElementById("modalNombre"),
    apellido: document.getElementById("modalApellido"),
    email: document.getElementById("modalEmail"),
    telefono: document.getElementById("modalTelefono"),
    rol: document.getElementById("modalRol"),
    estado: document.getElementById("modalEstado"),
    cedula: document.getElementById("modalCedula"),
    carnet: document.getElementById("modalCarnet"),
    fechaRegistro: document.getElementById("modalFechaRegistro"),
    equipmentSearchQuery: document.getElementById("equipmentSearchQuery"),
  };

  const newUserFields = {
    carnet: document.getElementById("newUserCarnet"),
    nombre: document.getElementById("newUserNombre"),
    apellido: document.getElementById("newUserApellido"),
    cedula: document.getElementById("newUserCedula"),
    email: document.getElementById("newUserEmail"),
    telefono: document.getElementById("newUserTelefono"),
    rol: document.getElementById("newUserRol"),
  };

  const newUserErrors = {
    nombre: document.getElementById("newUserNombreError"),
    apellido: document.getElementById("newUserApellidoError"),
    cedula: document.getElementById("newUserCedulaError"),
    email: document.getElementById("newUserEmailError"),
    telefono: document.getElementById("newUserTelefonoError"),
  };

  const newEquipmentFields = {
    serial: document.getElementById("newEquipmentSerial"),
    tipo: document.getElementById("newEquipmentTipo"),
    marca: document.getElementById("newEquipmentMarca"),
    modelo: document.getElementById("newEquipmentModelo"),
    descripcion: document.getElementById("newEquipmentDescripcion"),
  };

  const newEquipmentErrors = {
    serial: document.getElementById("newEquipmentSerialError"),
  };

  const USERS_PAGE_SIZE = 5;
  const EQUIPMENTS_PAGE_SIZE = 5;
  const editableKeys = ["nombre", "apellido", "email", "telefono", "rol", "estado"];
  const EQUIPMENT_PAGE_LIMIT = 100;
  let equipmentSearchDebounce = null;
  const COLOMBIA_TIME_ZONE = "America/Bogota";

  function getFullName(user) {
    return `${user.nombre} ${user.apellido}`.trim();
  }

  function formatDateTime(value) {
    if (!value) {
      return "--";
    }

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
      return String(value);
    }

    return date.toLocaleString("es-CO", {
      timeZone: COLOMBIA_TIME_ZONE,
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    });
  }

  function normalizeDate(value) {
    if (!value) {
      return "";
    }
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
      return String(value).slice(0, 10);
    }

    const parts = new Intl.DateTimeFormat("en-CA", {
      timeZone: COLOMBIA_TIME_ZONE,
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
    }).formatToParts(date);

    const year = parts.find((part) => part.type === "year")?.value ?? "";
    const month = parts.find((part) => part.type === "month")?.value ?? "";
    const day = parts.find((part) => part.type === "day")?.value ?? "";

    return year && month && day ? `${year}-${month}-${day}` : String(value).slice(0, 10);
  }

  function toUiStatus(status) {
    return String(status || "").toUpperCase() === "ACTIVO" ? "Activo" : "Inactivo";
  }

  function toBackendStatus(status) {
    return String(status || "").toLowerCase() === "activo" ? "ACTIVO" : "INACTIVO";
  }

  function getErrorDetail(payload, fallbackMessage) {
    if (typeof payload?.detail === "string" && payload.detail.trim()) {
      return payload.detail;
    }
    return fallbackMessage;
  }

  function getAuthToken() {
    return localStorage.getItem("scise-auth-token") || "";
  }

  function splitFullName(value) {
    const fullName = String(value || "").trim();
    if (!fullName) {
      return { nombre: "Sin nombre", apellido: "" };
    }

    const parts = fullName.split(/\s+/);
    const nombre = parts.shift() || fullName;
    const apellido = parts.join(" ");
    return { nombre, apellido };
  }

  function handleUnauthorized(detail = "Sesion no valida. Inicia sesion nuevamente.") {
    localStorage.removeItem("scise-auth-token");
    localStorage.removeItem("scise-session");
    alert(detail);
    window.location.href = "/auth/login";
  }

  function mapEstudianteToUser(estudiante) {
    const { nombre, apellido } = splitFullName(estudiante?.nombre);
    return {
      id: Number(estudiante?.id || 0),
      nombre,
      apellido,
      cedula: String(estudiante?.documento || ""),
      carnet: String(estudiante?.codigo_barras || ""),
      email: String(estudiante?.email || ""),
      telefono: String(estudiante?.celular || ""),
      rol: String(estudiante?.rol || "Aprendiz"),
      estado: toUiStatus(estudiante?.estado),
      fechaRegistro: String(estudiante?.fecha_registro || ""),
      equipos: [],
    };
  }

  function listFromPayload(payload) {
    if (Array.isArray(payload)) {
      return payload;
    }
    if (Array.isArray(payload?.data)) {
      return payload.data;
    }
    return [];
  }

  async function apiRequest(path, options = {}, fallbackError = "No fue posible completar la solicitud.") {
    const token = getAuthToken();
    if (!token) {
      handleUnauthorized();
      return null;
    }

    const requestOptions = {
      method: options.method || "GET",
      headers: {
        Authorization: `Bearer ${token}`,
        ...(options.body ? { "Content-Type": "application/json" } : {}),
        ...(options.headers || {}),
      },
      ...(options.body ? { body: JSON.stringify(options.body) } : {}),
    };

    const response = await fetch(`${API_BASE_URL}${path}`, requestOptions);
    if (response.status === 401) {
      const payload = await response.json().catch(() => ({}));
      handleUnauthorized(getErrorDetail(payload, "Sesion no valida. Inicia sesion nuevamente."));
      return null;
    }

    if (!response.ok) {
      const payload = await response.json().catch(() => ({}));
      throw new Error(getErrorDetail(payload, fallbackError));
    }

    if (response.status === 204) {
      return null;
    }

    return await response.json().catch(() => null);
  }

  async function hydrateUsersAndEquipments() {
    const [studentsPayload, equipmentsPayload] = await Promise.all([
      apiRequest("/estudiantes?skip=0&limit=500", {}, "No fue posible cargar estudiantes."),
      apiRequest("/equipos?skip=0&limit=100", {}, "No fue posible cargar equipos."),
    ]);

    const users = listFromPayload(studentsPayload).map(mapEstudianteToUser);
    const usersById = new Map(users.map((user) => [user.id, user]));

    listFromPayload(equipmentsPayload).forEach((equipo) => {
      const estudianteId = Number(equipo?.estudiante_id || 0);
      if (!estudianteId) {
        return;
      }

      let user = usersById.get(estudianteId);
      if (!user) {
        const splitName = splitFullName(equipo?.estudiante_nombre || "");
        user = {
          id: estudianteId,
          nombre: splitName.nombre || "Usuario",
          apellido: splitName.apellido,
          cedula: String(equipo?.estudiante_documento || ""),
          carnet: "",
          email: "",
          telefono: "",
          rol: "Aprendiz",
          estado: "Activo",
          fechaRegistro: "",
          equipos: [],
        };
        users.push(user);
        usersById.set(estudianteId, user);
      }

      user.equipos.push({
        id: Number(equipo?.id || 0),
        serial: String(equipo?.serial || ""),
        nombre: String(equipo?.nombre || "Equipo"),
        tipo: String(equipo?.tipo_equipo || "Otro"),
        estado: String(equipo?.estado || "SIN_ESTADO"),
        marca: "",
        modelo: "",
        descripcion: String(equipo?.descripcion || ""),
      });
    });

    state.users = users;
    state.userPage = 1;
    renderTable();
    renderEquipmentTable();
  }

  function getFilteredUsers() {
    const search = String(searchInput?.value || "").trim().toLowerCase();
    const role = String(roleFilter?.value || "");
    const status = String(statusFilter?.value || "");
    const date = String(dateFilter?.value || "");

    return state.users.filter((user) => {
      const matchesSearch =
        !search ||
        [user.nombre, user.apellido, getFullName(user), user.cedula, user.carnet, user.email].some((value) =>
          String(value).toLowerCase().includes(search)
        );

      const matchesRole = !role || user.rol === role;
      const matchesStatus = !status || user.estado === status;
      const matchesDate = !date || normalizeDate(user.fechaRegistro) === date;

      return matchesSearch && matchesRole && matchesStatus && matchesDate;
    });
  }

  function renderPagination(container, currentPage, totalPages, key) {
    if (!container) {
      return;
    }

    if (totalPages <= 1) {
      container.innerHTML = "";
      return;
    }

    const start = Math.max(1, currentPage - 2);
    const end = Math.min(totalPages, currentPage + 2);

    const buttons = [];
    buttons.push(
      `<button class="users-pagination__button" data-page-key="${key}" data-page="${currentPage - 1}" ${
        currentPage === 1 ? "disabled" : ""
      }>‹</button>`
    );

    for (let page = start; page <= end; page += 1) {
      buttons.push(
        `<button class="users-pagination__button ${page === currentPage ? "is-active" : ""}" data-page-key="${key}" data-page="${page}">${page}</button>`
      );
    }

    buttons.push(
      `<button class="users-pagination__button" data-page-key="${key}" data-page="${currentPage + 1}" ${
        currentPage === totalPages ? "disabled" : ""
      }>›</button>`
    );

    container.innerHTML = buttons.join("");
  }

  function renderTable() {
    const filteredUsers = getFilteredUsers();

    if (!tableBody || !emptyState) {
      return;
    }

    if (state.usersLoading) {
      tableBody.innerHTML = "";
      emptyState.hidden = false;
      emptyState.textContent = "Cargando usuarios desde la base de datos...";
      renderPagination(usersPagination, 1, 1, "users");
      return;
    }

    if (state.userErrorMessage) {
      tableBody.innerHTML = "";
      emptyState.hidden = false;
      emptyState.textContent = state.userErrorMessage;
      renderPagination(usersPagination, 1, 1, "users");
      return;
    }

    if (!filteredUsers.length) {
      tableBody.innerHTML = "";
      emptyState.hidden = false;
      emptyState.textContent = "No hay usuarios que coincidan con los filtros aplicados.";
      renderPagination(usersPagination, 1, 1, "users");
      return;
    }

    const totalPages = Math.max(1, Math.ceil(filteredUsers.length / USERS_PAGE_SIZE));
    state.userPage = Math.max(1, Math.min(state.userPage, totalPages));
    const start = (state.userPage - 1) * USERS_PAGE_SIZE;
    const visibleUsers = filteredUsers.slice(start, start + USERS_PAGE_SIZE);

    emptyState.hidden = true;
    tableBody.innerHTML = visibleUsers
      .map(
        (user) => `
          <tr>
            <td>
              <div class="users-table__identity">
                <strong>${getFullName(user)}</strong>
                <span>${user.telefono}</span>
              </div>
            </td>
            <td>${user.cedula}</td>
            <td>${user.carnet}</td>
            <td><span class="table-pill">${user.rol}</span></td>
            <td>${formatDateTime(user.fechaRegistro)}</td>
            <td>${user.email}</td>
            <td>
              <div class="users-table__actions">
                <button
                  class="status-toggle ${user.estado === "Activo" ? "is-active" : "is-inactive"}"
                  type="button"
                  data-action="toggle-status"
                  data-user-id="${user.id}"
                  aria-label="Cambiar estado"
                  ${sessionRole !== "admin" ? "disabled" : ""}
                >
                  <span class="status-toggle__track">
                    <span class="status-toggle__thumb"></span>
                  </span>
                </button>
                <button class="table-action" type="button" data-action="edit" data-user-id="${user.id}">
                  Editar
                </button>
              </div>
            </td>
          </tr>
        `
      )
      .join("");

    renderPagination(usersPagination, state.userPage, totalPages, "users");
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function getEquipmentFilters() {
    return {
      q: String(equipmentSearchInput?.value || "").trim(),
      tipo: String(equipmentTypeFilter?.value || "").trim(),
      estado: String(equipmentStatusFilter?.value || "").trim().toUpperCase(),
    };
  }

  function formatEquipmentStatus(status) {
    const normalized = String(status || "").toUpperCase();
    if (normalized === "DISPONIBLE") return "Disponible";
    if (normalized === "INGRESADO") return "Ingresado";
    if (normalized === "RETIRADO") return "Retirado";
    return normalized || "Sin estado";
  }

  function mapEquipmentItemFromApi(item) {
    const serial = String(item?.serial || "").trim();
    const nombre = String(item?.nombre || "").trim();
    const descripcion = String(item?.descripcion || "").trim();

    return {
      id: Number(item?.id || 0),
      serial: serial || "Sin serial",
      nombre: nombre || serial || "Sin nombre",
      tipo: String(item?.tipo_equipo || "").trim() || "Sin tipo",
      estado: String(item?.estado || "").trim(),
      descripcion,
      usuarioNombre: String(item?.estudiante_nombre || "").trim() || "Sin asignar",
      usuarioDocumento: String(item?.estudiante_documento || "").trim() || "Sin documento",
      codigoBarras: String(item?.codigo_barras_equipo || "").trim(),
      fechaRegistro: String(item?.fecha_registro || ""),
      estudianteId: Number(item?.estudiante_id || 0),
    };
  }

  function renderEquipmentTable() {
    if (!equipmentTableBody || !equipmentTableCount || !equipmentEmptyState) {
      return;
    }

    const total = Number(state.equipmentMeta?.total ?? state.equipments.length ?? 0);
    equipmentTableCount.textContent = String(total);

    if (state.equipmentLoading && !state.equipments.length) {
      equipmentTableBody.innerHTML = "";
      equipmentEmptyState.hidden = false;
      equipmentEmptyState.textContent = "Cargando equipos...";
      renderPagination(equipmentPagination, 1, 1, "equipments");
      return;
    }

    if (state.equipmentErrorMessage) {
      equipmentTableBody.innerHTML = "";
      equipmentEmptyState.hidden = false;
      equipmentEmptyState.textContent = state.equipmentErrorMessage;
      renderPagination(equipmentPagination, 1, 1, "equipments");
      return;
    }

    if (!state.equipments.length) {
      equipmentTableBody.innerHTML = "";
      equipmentEmptyState.hidden = false;
      equipmentEmptyState.textContent = "No hay equipos que coincidan con los filtros aplicados.";
      renderPagination(equipmentPagination, 1, 1, "equipments");
      return;
    }

    const totalPages = Math.max(1, Math.ceil(state.equipments.length / EQUIPMENTS_PAGE_SIZE));
    state.equipmentPage = Math.max(1, Math.min(state.equipmentPage, totalPages));
    const start = (state.equipmentPage - 1) * EQUIPMENTS_PAGE_SIZE;
    const visibleEquipments = state.equipments.slice(start, start + EQUIPMENTS_PAGE_SIZE);

    equipmentEmptyState.hidden = true;
    equipmentTableBody.innerHTML = visibleEquipments
      .map(
        (equipo) => `
          <tr>
            <td><strong>${escapeHtml(equipo.serial)}</strong></td>
            <td>
              <div class="users-table__identity">
                <strong>${escapeHtml(equipo.nombre)}</strong>
                <span>${escapeHtml(equipo.descripcion || equipo.codigoBarras || "Sin detalle")}</span>
              </div>
            </td>
            <td><span class="table-pill table-pill--neutral">${escapeHtml(equipo.tipo)}</span></td>
            <td>
              <div class="users-table__identity">
                <strong>${escapeHtml(equipo.usuarioNombre)}</strong>
                <span>${escapeHtml(equipo.usuarioDocumento)}</span>
              </div>
            </td>
            <td><span class="table-pill table-pill--status">${escapeHtml(formatEquipmentStatus(equipo.estado))}</span></td>
            <td>${escapeHtml(formatDateTime(equipo.fechaRegistro))}</td>
          </tr>
        `
      )
      .join("");

    renderPagination(equipmentPagination, state.equipmentPage, totalPages, "equipments");
  }

  function getSelectedUser() {
    return state.users.find((user) => user.id === state.selectedUserId) || null;
  }

  function setModalEditable() {
    const isAdmin = sessionRole === "admin";

    editableKeys.forEach((key) => {
      if (!modalFields[key]) {
        return;
      }

      if (key === "rol" || key === "estado") {
        modalFields[key].disabled = !isAdmin;
        return;
      }

      modalFields[key].disabled = false;
    });

    if (equipmentForm instanceof HTMLFormElement) {
      Array.from(equipmentForm.elements).forEach((element) => {
        element.disabled = false;
      });
    }

    if (saveUserButton) {
      saveUserButton.disabled = false;
    }

    if (permissionMessage) {
      permissionMessage.textContent = isAdmin
        ? "Modo administrador: puedes editar datos y gestionar equipos."
        : "Modo usuario: puedes editar datos del estudiante y gestionar equipos.";
      permissionMessage.className = isAdmin
        ? "user-modal__permissions is-admin"
        : "user-modal__permissions is-admin";
    }
  }

  function renderEquipmentList() {
    const selectedUser = getSelectedUser();

    if (!equipmentList || !selectedUser) {
      return;
    }

    if (!selectedUser.equipos.length) {
      equipmentList.innerHTML = `<p class="equipment-empty">No hay equipos asociados.</p>`;
      return;
    }

    equipmentList.innerHTML = selectedUser.equipos
      .map(
        (equipo) => `
          <article class="equipment-item">
            <div>
              <strong>${equipo.serial}</strong>
              <p>${equipo.nombre || equipo.descripcion || "Equipo"}</p>
              <span>${equipo.tipo} | ${formatEquipmentStatus(equipo.estado)}</span>
            </div>
          </article>
        `
      )
      .join("");
  }

  async function cargarEquiposAsociadosEnModal(estudianteId) {
    try {
      if (equipmentList) {
        equipmentList.innerHTML = `<p class="equipment-empty">Cargando equipos asociados...</p>`;
      }

      const payload = await apiRequest(
        `/estudiantes/${encodeURIComponent(estudianteId)}/equipos?solo_disponibles_ingreso=false`,
        {},
        "No fue posible cargar equipos asociados."
      );

      if (!payload) {
        return;
      }

      const user = getSelectedUser();
      if (!user) {
        return;
      }

      user.equipos = (Array.isArray(payload) ? payload : []).map((equipo) => ({
        id: Number(equipo?.id || 0),
        serial: String(equipo?.serial || ""),
        nombre: String(equipo?.nombre || ""),
        descripcion: String(equipo?.descripcion || ""),
        tipo: String(equipo?.tipo || "Sin tipo"),
        estado: String(equipo?.estado || ""),
      }));

      renderEquipmentList();
    } catch (error) {
      if (equipmentList) {
        equipmentList.innerHTML = `<p class="equipment-empty">${
          error instanceof Error ? escapeHtml(error.message) : "No fue posible cargar equipos asociados."
        }</p>`;
      }
    }
  }

  function renderResultadosBusquedaEquipos(items, message = "") {
    if (!equipmentSearchResults) {
      return;
    }

    if (!items.length) {
      equipmentSearchResults.innerHTML = `<p class="equipment-empty">${escapeHtml(message || "No hay resultados.")}</p>`;
      return;
    }

    const selectedUser = getSelectedUser();
    equipmentSearchResults.innerHTML = items
      .map((equipo) => {
        const alreadyAssigned = Number(equipo?.estudiante_id || 0) === Number(selectedUser?.id || 0);
        return `
          <article class="equipment-search-item">
            <div>
              <strong>${escapeHtml(equipo?.serial || "Sin serial")}</strong>
              <span>${escapeHtml(equipo?.nombre || "Equipo")} | ${escapeHtml(equipo?.tipo_equipo || "Sin tipo")} | ${escapeHtml(formatEquipmentStatus(equipo?.estado || ""))}</span>
            </div>
            <button class="table-action" type="button" data-action="associate-equipment" data-equipo-id="${Number(equipo?.id || 0)}" ${alreadyAssigned ? "disabled" : ""}>
              ${alreadyAssigned ? "Asignado" : "Asociar"}
            </button>
          </article>
        `;
      })
      .join("");
  }

