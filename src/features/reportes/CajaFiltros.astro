<section class="reportes-filter-card">
  <div class="reportes-filters">
    <label class="reportes-field">
      <span>Filtrar por Tipo</span>
      <select id="movementTypeFilter">
        <option value="">Todos los Movimientos</option>
        <option value="Ingreso">Ingresos</option>
        <option value="Salida">Salidas</option>
      </select>
    </label>

    <label class="reportes-field">
      <span>Fecha</span>
      <input id="movementDateFilter" type="date" />
    </label>
  </div>

  <div class="reportes-filter-actions">
    <button class="reportes-button reportes-button--ghost" id="reportesCsvButton" type="button">
      Descargar CSV
    </button>
    <button class="reportes-button reportes-button--accent" id="reportesPdfButton" type="button">
      Descargar PDF
    </button>
  </div>
</section>
