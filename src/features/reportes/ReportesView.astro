---
import CajaPanelInicial from "./CajaPanelInicial.astro";
import CajaEstadisticas from "./CajaEstadisticas.astro";
import CajaFiltros from "./CajaFiltros.astro";
import CajaHistorialMovimientos from "./CajaHistorialMovimientos.astro";
import CajaInformacion from "./CajaInformacion.astro";
---

<section class="reportes-page">
  <CajaPanelInicial />
  <CajaEstadisticas />
  <CajaFiltros />
  <CajaHistorialMovimientos />
  <CajaInformacion />
</section>

<script>
  import { formatMovementDateTime, type MovementReportRow, type MovementType } from "../../lib/movimientos";

  interface ReportesResumenResponse {
    total_equipos?: number;
    equipos_en_instalacion?: number;
    equipos_fuera_instalacion?: number;
    movimientos_hoy?: number;
    inside_pct?: number;
    outside_pct?: number;
    totalEquipos?: number;
    enInstalacion?: number;
    fueraInstalacion?: number;
    movimientosHoy?: number;
    insidePct?: number;
    outsidePct?: number;
  }

  interface HistorialApiMovimiento {
    id?: string | number;
    movimiento_id?: string | number;
    tipo?: string;
    tipo_movimiento?: string;
    estado?: string;
    fecha_hora?: string;
    fecha_registro?: string;
    timestamp?: string;
    serial?: string;
    equipo_id?: string | number;
    nombre_equipo?: string;
    equipo_nombre?: string;
    equipo_descripcion?: string;
    descripcion?: string;
    nombre_usuario?: string;
    usuario_nombre?: string;
    estudiante_nombre?: string;
    documento?: string;
    usuario_documento?: string;
    estudiante_documento?: string;
    usuario?: {
      nombre?: string;
      documento?: string;
    };
    estudiante?: {
      nombre?: string;
      documento?: string;
    };
    equipo?: {
      id?: string | number;
      nombre?: string;
      descripcion?: string;
      serial?: string;
    };
  }

  interface HistorialApiResponse {
    data?: HistorialApiMovimiento[];
    items?: HistorialApiMovimiento[];
    results?: HistorialApiMovimiento[];
    movimientos?: HistorialApiMovimiento[];
    meta?: {
      total?: number;
      skip?: number;
      limit?: number;
      has_next?: boolean;
      hasNext?: boolean;
      page?: number;
      current_page?: number;
      total_pages?: number;
    };
    total?: number;
    total_items?: number;
    total_registros?: number;
    page?: number;
    pagina?: number;
    current_page?: number;
    total_pages?: number;
    paginas?: number;
  }

  interface PaginationState {
    page: number;
    pageSize: number;
    totalItems: number;
    totalPages: number;
  }

  interface ReportFilters {
    tipo: string;
    fechaDesde: string;
    fechaHasta: string;
  }

  interface ReportesState {
    movements: MovementReportRow[];
    pagination: PaginationState;
    errorMessage: string;
  }

  const API_BASE_URL = (import.meta.env.PUBLIC_API_BASE_URL || "http://localhost:8000/api/v1").replace(/\/$/, "");

  const state: ReportesState = {
    movements: [],
    pagination: {
      page: 1,
      pageSize: 5,
      totalItems: 0,
      totalPages: 1,
    },
    errorMessage: "",
  };

  const tableBody = document.getElementById("reportesTableBody") as HTMLElement | null;
  const emptyState = document.getElementById("reportesEmptyState") as HTMLElement | null;
  const typeFilter = document.getElementById("movementTypeFilter") as HTMLSelectElement | null;
  const dateFromFilter = document.getElementById("movementDateFromFilter") as HTMLInputElement | null;
  const dateToFilter = document.getElementById("movementDateToFilter") as HTMLInputElement | null;
  const excelButton = document.getElementById("reportesExcelButton") as HTMLButtonElement | null;
  const pdfButton = document.getElementById("reportesPdfButton") as HTMLButtonElement | null;
  const allButton = document.getElementById("reportesAllButton") as HTMLButtonElement | null;
  const prevButton = document.getElementById("reportesPrevButton") as HTMLButtonElement | null;
  const nextButton = document.getElementById("reportesNextButton") as HTMLButtonElement | null;
  const pageInfo = document.getElementById("reportesPageInfo") as HTMLElement | null;

  const insideEquiposValue = document.getElementById("insideEquiposValue") as HTMLElement | null;
  const insideEquiposMeta = document.getElementById("insideEquiposMeta") as HTMLElement | null;
  const outsideEquiposValue = document.getElementById("outsideEquiposValue") as HTMLElement | null;
  const outsideEquiposMeta = document.getElementById("outsideEquiposMeta") as HTMLElement | null;
  const todayMovementsValue = document.getElementById("todayMovementsValue") as HTMLElement | null;
  const todayMovementsMeta = document.getElementById("todayMovementsMeta") as HTMLElement | null;
  const detailModal = document.getElementById("reportesDetailModal") as HTMLElement | null;
  const detailModalContent = document.getElementById("reportesDetailContent") as HTMLElement | null;
  const detailModalCloseButton = document.getElementById("reportesDetailCloseButton") as HTMLButtonElement | null;
  const detailModalFooterCloseButton = document.getElementById("reportesDetailFooterCloseButton") as HTMLButtonElement | null;
  const detailModalPrintButton = document.getElementById("reportesDetailPrintButton") as HTMLButtonElement | null;

  function getAuthToken(): string {
    return localStorage.getItem("scise-auth-token") || "";
  }

  function readSession(): Record<string, unknown> {
    try {
      const raw = localStorage.getItem("scise-session");
      if (!raw) {
        return {};
      }
      const parsed = JSON.parse(raw);
      return parsed && typeof parsed === "object" ? parsed : {};
    } catch {
      return {};
    }
  }

  function resolveIsAdmin(session: Record<string, unknown>): boolean {
    const roleValue = String(session?.role || session?.rol || "").toLowerCase();
    const backendRole = String(session?.roleBackend || "").toUpperCase();
    return roleValue === "admin" || roleValue === "administrador" || backendRole === "ADMINISTRADOR";
  }

  const sessionData = readSession();
  const isAdmin = resolveIsAdmin(sessionData);

  if (!isAdmin) {
    excelButton?.setAttribute("hidden", "true");
    pdfButton?.setAttribute("hidden", "true");
    allButton?.setAttribute("hidden", "true");
  }

  function handleUnauthorized(detail?: string): void {
    localStorage.removeItem("scise-auth-token");
    localStorage.removeItem("scise-session");
    state.errorMessage = detail || "Sesión vencida. Inicia sesión nuevamente.";
    renderTable();
    window.setTimeout(() => {
      window.location.href = "/auth/login";
    }, 900);
  }

  function getForbiddenMessage(detail?: string): string {
    if (detail && detail.trim()) {
      return detail;
    }
    return "No tienes permisos para consultar reportes. Accede con rol Administrador.";
  }

  async function getResponseDetail(response: Response, fallback: string): Promise<string> {
    const payload = await response.json().catch(() => ({}));
    if (typeof payload?.detail === "string" && payload.detail.trim()) {
      return payload.detail;
    }
    return fallback;
  }

  async function handleAuthStatus(response: Response): Promise<void> {
    if (response.status === 401) {
      const detail = await getResponseDetail(response, "Sesión no autorizada.");
      handleUnauthorized(detail);
      throw new Error(detail);
    }

    if (response.status === 403) {
      const detail = await getResponseDetail(
        response,
        "No tienes permisos para consultar reportes. Accede con rol Administrador."
      );
      throw new Error(getForbiddenMessage(detail));
    }
  }

  function normalizeMovementType(value: unknown): MovementType {
    const normalized = String(value || "").toUpperCase();
    return normalized === "SALIDA" ? "Salida" : "Ingreso";
  }

  function mapApiMovementToReportRow(item: HistorialApiMovimiento): MovementReportRow {
    const tipo = normalizeMovementType(item.tipo_movimiento || item.tipo);
    const equipoInfo = item.equipo || {};
    const usuarioInfo = item.usuario || item.estudiante || {};
    const fechaHora = String(item.fecha_registro || item.fecha_hora || item.timestamp || "");
    const equipoId = String(item.equipo_id || equipoInfo.id || "");
    const serial = String(item.serial || equipoInfo.serial || "");
    const equipo = String(
      item.equipo_descripcion ||
      item.nombre_equipo ||
      item.equipo_nombre ||
      item.descripcion ||
      equipoInfo.descripcion ||
      equipoInfo.nombre ||
      "Equipo"
    );
    const nombre = String(
      item.nombre_usuario ||
      item.usuario_nombre ||
      item.estudiante_nombre ||
      usuarioInfo.nombre ||
      "Usuario"
    );
    const documento = String(
      item.usuario_documento ||
      item.estudiante_documento ||
      item.documento ||
      usuarioInfo.documento ||
      "-"
    );

    return {
      id: String(item.movimiento_id || item.id || `${equipoId}-${fechaHora}`),
      tipo,
      nombre,
      documento,
      equipo,
      equipoId,
      serial,
      fechaHora,
      estado: String(item.estado || "Completado"),
    };
  }

  function parseHistorialResponse(
    payload: unknown,
    pageFallback: number,
    pageSizeFallback: number
  ): { rows: MovementReportRow[]; totalItems: number; page: number; totalPages: number } {
    if (Array.isArray(payload)) {
      const rows = payload.map((item) => mapApiMovementToReportRow(item as HistorialApiMovimiento));
      const totalItems = rows.length;
      return {
        rows,
        totalItems,
        page: pageFallback,
        totalPages: Math.max(1, Math.ceil(totalItems / pageSizeFallback)),
      };
    }

    const body = (payload || {}) as HistorialApiResponse;
    const meta = body.meta || {};
    const rawRows = body.data || body.items || body.results || body.movimientos || [];
    const rows = (Array.isArray(rawRows) ? rawRows : []).map((item) =>
      mapApiMovementToReportRow(item as HistorialApiMovimiento)
    );

    const totalItems = Number(body.total ?? body.total_items ?? body.total_registros ?? meta.total ?? rows.length);
    const limit = Number(meta.limit ?? pageSizeFallback);
    const skip = Number(meta.skip ?? (pageFallback - 1) * pageSizeFallback);
    const derivedPageFromSkip =
      Number.isFinite(limit) && limit > 0 && Number.isFinite(skip) && skip >= 0
        ? Math.floor(skip / limit) + 1
        : pageFallback;
    const page = Number(
      body.page ??
      body.pagina ??
      body.current_page ??
      meta.page ??
      meta.current_page ??
      derivedPageFromSkip
    );
    const totalPages = Number(
      body.total_pages ??
      body.paginas ??
      meta.total_pages ??
      (Number.isFinite(limit) && limit > 0
        ? Math.max(1, Math.ceil(totalItems / limit))
        : Math.max(1, Math.ceil(totalItems / pageSizeFallback)))
    );

    return {
      rows,
      totalItems: Number.isFinite(totalItems) ? totalItems : rows.length,
      page: Number.isFinite(page) && page > 0 ? page : pageFallback,
      totalPages: Number.isFinite(totalPages) && totalPages > 0 ? totalPages : 1,
    };
  }

  function formatDateTime(value: string): string {
    if (!value) {
      return "Sin fecha";
    }
    return formatMovementDateTime(value);
  }

  function escapeHtml(value: string): string {
    return value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function formatDetailLabel(key: string): string {
    const labels: Record<string, string> = {
      id: "ID",
      movimiento_id: "ID Movimiento",
      tipo_movimiento: "Tipo Movimiento",
      fecha_registro: "Fecha Registro",
      fecha_hora: "Fecha Hora",
      estado: "Estado",
      equipo_id: "Equipo ID",
      serial: "Serial",
      nombre_equipo: "Equipo",
      equipo_nombre: "Equipo",
      equipo_descripcion: "Descripción Equipo",
      nombre_usuario: "Usuario",
      usuario_nombre: "Usuario",
      documento: "Documento",
      usuario_documento: "Documento",
      estudiante_nombre: "Estudiante",
      estudiante_documento: "Documento Estudiante",
      usuario_id: "Usuario ID",
      estudiante_id: "Estudiante ID",
    };

    if (labels[key]) {
      return labels[key];
    }
    return key.replaceAll("_", " ").replace(/\b\w/g, (letter) => letter.toUpperCase());
  }

  function formatDetailValue(value: unknown): string {
    if (value === null || value === undefined || value === "") {
      return "-";
    }
    if (typeof value === "string" || typeof value === "number" || typeof value === "boolean") {
      return String(value);
    }
    try {
      return JSON.stringify(value);
    } catch {
      return String(value);
    }
  }

  function closeDetailModal(): void {
    if (detailModal) {
      detailModal.hidden = true;
    }
    document.body.classList.remove("reportes-modal-open");
  }

  function openDetailModal(detalle: Record<string, unknown>): void {
    if (!detailModal || !detailModalContent) {
      return;
    }

    const preferredOrder = [
      "id",
      "movimiento_id",
      "tipo_movimiento",
      "fecha_registro",
      "fecha_hora",
      "estado",
      "equipo_id",
      "serial",
      "nombre_equipo",
      "equipo_nombre",
      "equipo_descripcion",
      "nombre_usuario",
      "usuario_nombre",
      "documento",
      "usuario_documento",
      "estudiante_nombre",
      "estudiante_documento",
      "usuario_id",
      "estudiante_id",
    ];

    const entries = Object.entries(detalle || {});
    const orderedEntries = [
      ...preferredOrder
        .filter((key) => entries.some(([entryKey]) => entryKey === key))
        .map((key) => entries.find(([entryKey]) => entryKey === key) as [string, unknown]),
      ...entries.filter(([entryKey]) => !preferredOrder.includes(entryKey)),
    ];

    if (!orderedEntries.length) {
      detailModalContent.innerHTML = `
        <article class="reportes-detail-item">
          <strong>Detalle</strong>
          <span>No hay información disponible para este movimiento.</span>
        </article>
      `;
    } else {
      detailModalContent.innerHTML = orderedEntries
        .map(
          ([key, value]) => `
            <article class="reportes-detail-item">
              <strong>${escapeHtml(formatDetailLabel(key))}</strong>
              <span>${escapeHtml(formatDetailValue(value))}</span>
            </article>
          `
        )
        .join("");
    }

    detailModal.hidden = false;
    document.body.classList.add("reportes-modal-open");
  }

  function getFilters(): ReportFilters {
    return {
      tipo: String(typeFilter?.value || ""),
      fechaDesde: String(dateFromFilter?.value || ""),
      fechaHasta: String(dateToFilter?.value || ""),
    };
  }

  function normalizeFilterType(value: string): string {
    const normalized = value.trim().toUpperCase();
    if (normalized.startsWith("INGRESO")) {
      return "INGRESO";
    }
    if (normalized.startsWith("SALIDA")) {
      return "SALIDA";
    }
    return "";
  }

  function isValidDateRange(filters: ReportFilters): boolean {
    if (!filters.fechaDesde || !filters.fechaHasta) {
      return true;
    }
    return new Date(filters.fechaDesde).getTime() <= new Date(filters.fechaHasta).getTime();
  }

  function buildFilterQuery(filters: ReportFilters): URLSearchParams {
    const query = new URLSearchParams();
    const tipo = normalizeFilterType(filters.tipo);
    if (tipo) {
      query.set("tipo", tipo);
      query.set("tipo_movimiento", tipo);
    }
    if (filters.fechaDesde) {
      query.set("fecha_inicio", filters.fechaDesde);
      query.set("fecha_desde", filters.fechaDesde);
    }
    if (filters.fechaHasta) {
      query.set("fecha_fin", filters.fechaHasta);
      query.set("fecha_hasta", filters.fechaHasta);
    }
    if (filters.fechaDesde && filters.fechaHasta && filters.fechaDesde === filters.fechaHasta) {
      query.set("fecha", filters.fechaDesde);
    }
    return query;
  }

  async function fetchResumenFromApi(filters: ReportFilters): Promise<void> {
    const token = getAuthToken();
    if (!token) {
      throw new Error("Sesión no válida. Inicia sesión nuevamente.");
    }

    const query = buildFilterQuery(filters);
    const url = query.toString()
      ? `${API_BASE_URL}/${isAdmin ? "reportes/movimientos/resumen" : "dashboard/resumen"}?${query.toString()}`
      : `${API_BASE_URL}/${isAdmin ? "reportes/movimientos/resumen" : "dashboard/resumen"}`;

    const response = await fetch(url, {
      method: "GET",
      headers: {
        Authorization: `Bearer ${token}`,
      },
    });

    if (!response.ok) {
      await handleAuthStatus(response);
      const detail = await getResponseDetail(response, "No fue posible cargar el resumen.");
      throw new Error(detail);
    }

    const payload = (await response.json()) as ReportesResumenResponse;
    const totalEquipos = Number(payload.total_equipos ?? payload.totalEquipos ?? 0);
    const enInstalacion = Number(payload.equipos_en_instalacion ?? payload.enInstalacion ?? 0);
    const fueraInstalacion = Number(payload.equipos_fuera_instalacion ?? payload.fueraInstalacion ?? 0);
    const movimientosHoy = Number(payload.movimientos_hoy ?? payload.movimientosHoy ?? 0);
    const insidePct = Number(
      payload.inside_pct ??
      payload.insidePct ??
      (totalEquipos ? Math.round((enInstalacion / totalEquipos) * 100) : 0)
    );
    const outsidePct = Number(
      payload.outside_pct ??
      payload.outsidePct ??
      (totalEquipos ? Math.round((fueraInstalacion / totalEquipos) * 100) : 0)
    );

    if (insideEquiposValue) insideEquiposValue.textContent = String(enInstalacion);
    if (insideEquiposMeta) insideEquiposMeta.textContent = `${insidePct}% del inventario actual`;
    if (outsideEquiposValue) outsideEquiposValue.textContent = String(fueraInstalacion);
    if (outsideEquiposMeta) outsideEquiposMeta.textContent = `${outsidePct}% del inventario actual`;
    if (todayMovementsValue) todayMovementsValue.textContent = String(movimientosHoy);
    if (todayMovementsMeta) todayMovementsMeta.textContent = `${movimientosHoy} movimientos registrados`;
  }

  async function fetchHistorialPageFromApi(
    page: number,
    pageSize: number,
    filters: ReportFilters
  ): Promise<{ rows: MovementReportRow[]; totalItems: number; page: number; totalPages: number }> {
    const token = getAuthToken();
    if (!token) {
      throw new Error("Sesión no válida. Inicia sesión nuevamente.");
    }

    const query = buildFilterQuery(filters);
    const safePage = Math.max(1, page);
    const safePageSize = Math.max(1, pageSize);
    if (isAdmin) {
      const skip = (safePage - 1) * safePageSize;
      query.set("skip", String(skip));
      query.set("limit", String(safePageSize));
      query.set("page", String(safePage));
      query.set("page_size", String(safePageSize));
    } else {
      query.set("page", String(safePage));
      query.set("limit", String(safePageSize));
    }

    const endpoint = isAdmin ? "reportes/movimientos/historial" : "dashboard/historial-reciente";
    const response = await fetch(`${API_BASE_URL}/${endpoint}?${query.toString()}`, {
      method: "GET",
      headers: {
        Authorization: `Bearer ${token}`,
      },
    });

    if (!response.ok) {
      await handleAuthStatus(response);
      const detail = await getResponseDetail(response, "No fue posible cargar el historial.");
      throw new Error(detail);
    }

    const payload = await response.json().catch(() => ({}));
    return parseHistorialResponse(payload, page, pageSize);
  }

  function renderTable(): void {
    if (!tableBody || !emptyState || !pageInfo || !prevButton || !nextButton) {
      return;
    }

    const totalPages = state.pagination.totalPages;
    pageInfo.textContent = `Página ${state.pagination.page} de ${totalPages}`;
    prevButton.disabled = state.pagination.page <= 1;
    nextButton.disabled = state.pagination.page >= totalPages;

    if (!state.movements.length) {
      tableBody.innerHTML = "";
      emptyState.hidden = false;
      emptyState.textContent = state.errorMessage || "No hay movimientos que coincidan con los filtros aplicados.";
      return;
    }

    emptyState.hidden = true;
    tableBody.innerHTML = state.movements
      .map(
        (movement: MovementReportRow) => `
          <tr>
            <td>
              <span class="movement-pill ${movement.tipo === "Ingreso" ? "is-ingreso" : "is-salida"}">
                ${movement.tipo}
              </span>
            </td>
            <td>
              <div class="movement-user">
                <strong>${movement.nombre}</strong>
                <span>${movement.documento}</span>
              </div>
            </td>
            <td>${movement.equipo}</td>
            <td>${movement.serial}</td>
            <td>${formatDateTime(movement.fechaHora)}</td>
            <td><span class="movement-status">${movement.estado}</span></td>
            <td>
              <button class="movement-more" type="button" data-movement-id="${movement.id}" aria-label="Ver detalle del movimiento">
                Detalle
              </button>
            </td>
          </tr>
        `
      )
      .join("");
  }

  function getDownloadFilename(contentDisposition: string | null, fallback: string): string {
    if (!contentDisposition) {
      return fallback;
    }
    const utf8Match = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
    if (utf8Match?.[1]) {
      return decodeURIComponent(utf8Match[1]);
    }
    const quotedMatch = contentDisposition.match(/filename="([^"]+)"/i);
    if (quotedMatch?.[1]) {
      return quotedMatch[1];
    }
    const plainMatch = contentDisposition.match(/filename=([^;]+)/i);
    if (plainMatch?.[1]) {
      return plainMatch[1].trim();
    }
    return fallback;
  }

  async function downloadExcelWithFilters(filters: ReportFilters, fallbackFilename: string): Promise<void> {
    const token = getAuthToken();
    if (!token) {
      throw new Error("Sesión no válida. Inicia sesión nuevamente.");
    }

    const query = buildFilterQuery(filters);
    const endpoints = [
      `${API_BASE_URL}/reportes/movimientos/export.xlsx`,
      `${API_BASE_URL}/reportes/movimientos/export/xlsx`,
      `${API_BASE_URL}/reportes/movimientos/xlsx`,
      `${API_BASE_URL}/reportes/movimientos/export.csv`,
      `${API_BASE_URL}/reportes/movimientos/export/csv`,
      `${API_BASE_URL}/reportes/movimientos/csv`,
    ];

    let lastError = "No fue posible descargar el archivo Excel.";

    for (const endpoint of endpoints) {
      const url = query.toString() ? `${endpoint}?${query.toString()}` : endpoint;
      const response = await fetch(url, {
        method: "GET",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet, text/csv",
        },
      });

      await handleAuthStatus(response);

      if (!response.ok) {
        if (response.status === 404 || response.status === 405) {
          lastError = `Endpoint no disponible en ${endpoint}`;
          continue;
        }

        const detail = await getResponseDetail(response, "No fue posible descargar el archivo Excel.");
        throw new Error(detail);
      }

      const blob = await response.blob();
      if (!blob || !blob.size) {
        lastError = "El archivo de Excel llego vacio.";
        continue;
      }

      const objectUrl = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = objectUrl;
      link.download = getDownloadFilename(response.headers.get("content-disposition"), fallbackFilename);
      link.click();
      URL.revokeObjectURL(objectUrl);
      return;
    }

    throw new Error(lastError);
  }

  async function downloadPdfWithFilters(filters: ReportFilters): Promise<void> {
    const token = getAuthToken();
    if (!token) {
      throw new Error("Sesión no válida. Inicia sesión nuevamente.");
    }

    const query = buildFilterQuery(filters);
    const endpoints = [
      `${API_BASE_URL}/reportes/movimientos/export.pdf`,
      `${API_BASE_URL}/reportes/movimientos/historial/pdf`,
      `${API_BASE_URL}/reportes/movimientos/pdf`,
      `${API_BASE_URL}/reportes/movimientos/export/pdf`,
    ];

    let lastError = "No fue posible descargar PDF.";

    for (const endpoint of endpoints) {
      const url = query.toString() ? `${endpoint}?${query.toString()}` : endpoint;
      const response = await fetch(url, {
        method: "GET",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/pdf",
        },
      });

      await handleAuthStatus(response);

      if (!response.ok) {
        if (response.status === 404 || response.status === 405) {
          lastError = `Endpoint no disponible en ${endpoint}`;
          continue;
        }

        const detail = await getResponseDetail(response, "No fue posible descargar PDF.");
        throw new Error(detail);
      }

      const blob = await response.blob();
      if (!blob || !blob.size) {
        lastError = "El archivo PDF llego vacio.";
        continue;
      }

      const objectUrl = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = objectUrl;
      link.download = "reporte-movimientos.pdf";
      link.click();
      URL.revokeObjectURL(objectUrl);
      return;
    }

    throw new Error(lastError);
  }

  async function fetchMovimientoDetalleById(movimientoId: string): Promise<Record<string, unknown>> {
    const token = getAuthToken();
    if (!token) {
      throw new Error("Sesión no válida. Inicia sesión nuevamente.");
    }

    const endpoints = [
      `${API_BASE_URL}/movimientos/${encodeURIComponent(movimientoId)}`,
      `${API_BASE_URL}/reportes/movimientos/${encodeURIComponent(movimientoId)}`,
      `${API_BASE_URL}/reportes/movimientos/historial/${encodeURIComponent(movimientoId)}`,
    ];

    for (const endpoint of endpoints) {
      const response = await fetch(endpoint, {
        method: "GET",
        headers: {
          Authorization: `Bearer ${token}`,
        },
      });

      await handleAuthStatus(response);

      if (response.ok) {
        const payload = await response.json().catch(() => ({}));
        if (payload && typeof payload === "object" && "data" in (payload as Record<string, unknown>)) {
          return ((payload as { data?: Record<string, unknown> }).data || {}) as Record<string, unknown>;
        }
        return (payload || {}) as Record<string, unknown>;
      }

      if (response.status !== 404 && response.status !== 405) {
        const detail = await getResponseDetail(response, "No fue posible consultar detalle del movimiento.");
        throw new Error(detail);
      }
    }

    throw new Error("No existe endpoint de detalle para este movimiento.");
  }

  async function loadReportes(page = 1): Promise<void> {
    const filters = getFilters();
    state.pagination.page = Math.max(1, page);
    state.errorMessage = "";

    if (!isValidDateRange(filters)) {
      state.movements = [];
      state.pagination.totalItems = 0;
      state.pagination.totalPages = 1;
      state.errorMessage = "El rango de fechas no es valido: la fecha inicial no puede ser mayor a la final.";
      renderTable();
      return;
    }

    try {
      const [_, historial] = await Promise.all([
        fetchResumenFromApi(filters),
        fetchHistorialPageFromApi(state.pagination.page, state.pagination.pageSize, filters),
      ]);

      state.movements = historial.rows;
      state.pagination.page = historial.page;
      state.pagination.totalItems = historial.totalItems;
      state.pagination.totalPages = historial.totalPages;
    } catch (error) {
      state.movements = [];
      state.pagination.totalItems = 0;
      state.pagination.totalPages = 1;
      state.errorMessage =
        error instanceof Error ? error.message : "No fue posible cargar reportes desde API.";
      if (insideEquiposValue) insideEquiposValue.textContent = "0";
      if (insideEquiposMeta) insideEquiposMeta.textContent = "Sin datos de API";
      if (outsideEquiposValue) outsideEquiposValue.textContent = "0";
      if (outsideEquiposMeta) outsideEquiposMeta.textContent = "Sin datos de API";
      if (todayMovementsValue) todayMovementsValue.textContent = "0";
      if (todayMovementsMeta) todayMovementsMeta.textContent = "Sin datos de API";
    }

    renderTable();
  }

  typeFilter?.addEventListener("change", () => {
    loadReportes(1);
  });

  dateFromFilter?.addEventListener("change", () => {
    loadReportes(1);
  });

  dateToFilter?.addEventListener("change", () => {
    loadReportes(1);
  });

  excelButton?.addEventListener("click", async () => {
    try {
      const filters = getFilters();
      if (!isValidDateRange(filters)) {
        state.errorMessage = "El rango de fechas no es valido para exportar.";
        renderTable();
        return;
      }
      await downloadExcelWithFilters(filters, "movimientos-filtrados.xlsx");
    } catch (error) {
      state.errorMessage =
        error instanceof Error ? error.message : "No fue posible exportar Excel.";
      renderTable();
    }
  });

  allButton?.addEventListener("click", async () => {
    try {
      await downloadExcelWithFilters({
        tipo: "",
        fechaDesde: "",
        fechaHasta: "",
      }, "movimientos-completos.xlsx");
    } catch (error) {
      state.errorMessage =
        error instanceof Error ? error.message : "No fue posible descargar el historial completo.";
      renderTable();
    }
  });

  pdfButton?.addEventListener("click", async () => {
    try {
      const filters = getFilters();
      if (!isValidDateRange(filters)) {
        state.errorMessage = "El rango de fechas no es valido para exportar PDF.";
        renderTable();
        return;
      }
      await downloadPdfWithFilters(filters);
    } catch (error) {
      state.errorMessage =
        error instanceof Error ? error.message : "No fue posible exportar PDF.";
      renderTable();
    }
  });

  prevButton?.addEventListener("click", () => {
    if (state.pagination.page > 1) {
      loadReportes(state.pagination.page - 1);
    }
  });

  nextButton?.addEventListener("click", () => {
    if (state.pagination.page < state.pagination.totalPages) {
      loadReportes(state.pagination.page + 1);
    }
  });

  tableBody?.addEventListener("click", (event) => {
    const target = event.target instanceof HTMLElement ? event.target.closest("button") : null;
    if (!(target instanceof HTMLButtonElement)) {
      return;
    }
    if (target.classList.contains("movement-more")) {
      const movementId = String(target.dataset.movementId || "");
      if (!movementId) {
        state.errorMessage = "No se encontró el ID del movimiento.";
        renderTable();
        return;
      }

      fetchMovimientoDetalleById(movementId)
        .then((detalle) => {
          openDetailModal(detalle);
        })
        .catch((error) => {
          state.errorMessage =
            error instanceof Error ? error.message : "No fue posible consultar detalle.";
          renderTable();
        });
    }
  });

  detailModalCloseButton?.addEventListener("click", () => {
    closeDetailModal();
  });

  detailModalFooterCloseButton?.addEventListener("click", () => {
    closeDetailModal();
  });

  detailModalPrintButton?.addEventListener("click", () => {
    if (!detailModalContent) {
      return;
    }

    const printWindow = window.open("", "_blank", "width=900,height=700");
    if (!printWindow) {
      state.errorMessage = "No fue posible abrir la ventana de impresion.";
      renderTable();
      return;
    }

    printWindow.document.write(`
      <html>
        <head>
          <title>Detalle de Movimiento</title>
          <style>
            body { font-family: Arial, sans-serif; padding: 24px; color: #0f172a; }
            h1 { margin: 0 0 16px; font-size: 20px; }
            .item { border: 1px solid #e2e8f0; border-radius: 10px; padding: 10px 12px; margin-bottom: 10px; }
            .item strong { display: block; font-size: 12px; color: #64748b; text-transform: uppercase; margin-bottom: 6px; }
          </style>
        </head>
        <body>
          <h1>Detalle de Movimiento</h1>
          ${detailModalContent.innerHTML.replaceAll('class="reportes-detail-item"', 'class="item"')}
        </body>
      </html>
    `);
    printWindow.document.close();
    printWindow.focus();
    printWindow.print();
    printWindow.close();
  });

  detailModal?.addEventListener("click", (event) => {
    const target = event.target instanceof HTMLElement ? event.target : null;
    if (target?.closest("[data-close-reportes-modal]")) {
      closeDetailModal();
    }
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && detailModal && !detailModal.hidden) {
      closeDetailModal();
    }
  });

  window.addEventListener("scise:movimientos-updated", () => {
    loadReportes(state.pagination.page);
  });

  loadReportes(1);
</script>
